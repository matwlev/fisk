def cmd_import(args):
    """Import transactions from an external CSV file."""
    name = args.ledger
    if not ledger_path(name).exists():
        print(f"Ledger '{name}' not found. Create it first with: fisk create {name}")
        return
    src = Path(args.file)
    if not src.exists():
        print(f"File not found: {src}")
        return

    rows = read_ledger(name)
    with open(src, newline="", encoding="utf-8-sig") as f:
        reader = csv.DictReader(f)
        headers = reader.fieldnames
        print(f"  Source columns: {headers}")

        # Column mapping
        date_col = args.date_col or next((h for h in headers if h.lower().strip() == "date"), None)
        desc_col = args.desc_col or next((h for h in headers if h.lower().strip() == "description"), None)
        credit_col = args.credit_col or next((h for h in headers if h.lower().strip() == "credit"), None)
        debit_col = args.debit_col or next((h for h in headers if h.lower().strip() == "debit"), None)
        amount_col = args.amount_col or next((h for h in headers if h.lower().strip() == "amount"), None)
        category_col = args.category_col or next((h for h in headers if h.lower().strip() == "category"), None)
        cleared_col = args.cleared_col or next((h for h in headers if h.strip() in ("✓", "✔", "Cleared", "cleared")), None)

        if not date_col or not desc_col:
            print("  Could not auto-detect date/description columns. Use --date-col and --desc-col.")
            return
        if not credit_col and not debit_col and not amount_col:
            print("  Could not detect amount columns. Use --amount-col or --credit-col/--debit-col.")
            return

        count = 0
        date_fmt = args.date_format if hasattr(args, "date_format") else None
        for row in reader:
            d = row.get(date_col, "").strip()
            if not d:
                continue
            # Try to parse date
            parsed_date = None
            if date_fmt:
                try:
                    from datetime import datetime
                    parsed_date = datetime.strptime(d, date_fmt).date()
                except ValueError:
                    print(f"  Skipping row with unparseable date: {d}")
                    continue
            else:
                try:
                    parsed_date = date.fromisoformat(d)
                except ValueError:
                    for fmt in ("%m/%d/%Y", "%m/%d/%y", "%d/%m/%Y"):
                        try:
                            from datetime import datetime
                            parsed_date = datetime.strptime(d, fmt).date()
                            break
                        except ValueError:
                            continue
                    else:
                        print(f"  Skipping row with unparseable date: {d}")
                        continue

            desc = row.get(desc_col, "").strip()
            if not desc:
                continue

            # Compute amount
            if amount_col:
                amt_str = row.get(amount_col, "").strip().replace(",", "").replace("$", "")
                if not amt_str:
                    continue
                amt = Decimal(amt_str)
            else:
                credit_str = row.get(credit_col, "").strip().replace(",", "").replace("$", "") if credit_col else ""
                debit_str = row.get(debit_col, "").strip().replace(",", "").replace("$", "") if debit_col else ""
                if credit_str:
                    amt = Decimal(credit_str)
                elif debit_str:
                    amt = -abs(Decimal(debit_str))
                else:
                    continue

            cat = row.get(category_col, "").strip() if category_col else ""

            # Status from cleared column
            if cleared_col:
                cleared_val = row.get(cleared_col, "").strip()
                status = "cleared" if cleared_val else "pending"
            else:
                status = "pending"

            if parsed_date > date.today():
                status = "future"

            rows.append({
                "id": str(next_id(rows)),
                "date": parsed_date.isoformat(),
                "description": desc,
                "amount": str(amt),
                "category": cat,
                "status": status,
                "notes": "",
            })
            count += 1

    write_ledger(name, rows)
    print(f"  Imported {count} transactions into '{name}'.")


def cmd_sort_noninteractive(args):
    rows = read_ledger(args.ledger)
    if rows is None:
        return
    if args.id and args.position:
        row = next((r for r in rows if r["id"] == args.id), None)
        if not row:
            print(f"Transaction {args.id} not found.")
            return
        rows.remove(row)
        idx = max(0, min(args.position - 1, len(rows)))
        rows.insert(idx, row)
        for i, r in enumerate(rows, 1):
            r["id"] = str(i)
        write_ledger(args.ledger, rows)
        print(f"Moved to #{args.position}. IDs reassigned.")
    else:
        sorted_rows = sorted(rows, key=lambda x: (x["date"], int(x["id"])))
        for i, r in enumerate(sorted_rows, 1):
            r["id"] = str(i)
        write_ledger(args.ledger, sorted_rows)
        print("Sorted by date. IDs reassigned.")


def cmd_summary(args):
    rows = read_ledger(args.ledger)
    if rows is None:
        return
    # Filter out starting balance
    txns = [r for r in rows if r["status"] != "starting"]
    # Apply filters
    if args.description:
        term = args.description.lower()
        txns = [r for r in txns if term in r["description"].lower()]
    if args.category:
        term = args.category.lower()
        txns = [r for r in txns if r["category"].lower() == term]
    if args.start_date:
        start = parse_date_or_relative(args.start_date)
        txns = [r for r in txns if date.fromisoformat(r["date"]) >= start]
    if args.end_date:
        end = parse_date_or_relative(args.end_date)
        txns = [r for r in txns if date.fromisoformat(r["date"]) <= end]
    if not txns:
        print("  No matching transactions.")
        return
    amounts = [Decimal(r["amount"]) for r in txns]
    debits = [a for a in amounts if a < 0]
    credits = [a for a in amounts if a > 0]
    total = sum(amounts)
    print(f"  Transactions:  {len(txns)}")
    print(f"  Total:         ${total:,.2f}")
    if debits:
        print(f"  Total spent:   ${sum(debits):,.2f}")
        print(f"  Highest debit: ${min(debits):,.2f}")
        print(f"  Lowest debit:  ${max(debits):,.2f}")
        print(f"  Avg debit:     ${sum(debits) / len(debits):,.2f}")
    if credits:
        print(f"  Total income:  ${sum(credits):,.2f}")
        print(f"  Highest credit:${max(credits):,.2f}")
        print(f"  Lowest credit: ${min(credits):,.2f}")
        print(f"  Avg credit:    ${sum(credits) / len(credits):,.2f}")
    if not args.description and not args.category:
        # Show breakdown by category
        cats = {}
        for r in txns:
            cat = r["category"] or "(uncategorized)"
            cats.setdefault(cat, Decimal("0"))
            cats[cat] += Decimal(r["amount"])
        print(f"\n  By category:")
        for cat, amt in sorted(cats.items(), key=lambda x: x[1]):
            print(f"    {cat:<20} ${amt:>10,.2f}")

        # Top 10s by description
        descs = {}
        for r in txns:
            d = r["description"]
            descs.setdefault(d, []).append(Decimal(r["amount"]))

        print(f"\n  Top 10 by total spent:")
        by_total = sorted(descs.items(), key=lambda x: sum(x[1]))
        for desc, amts in by_total[:10]:
            if sum(amts) >= 0:
                continue
            print(f"    {desc:<20} ${sum(amts):>10,.2f}  ({len(amts)} txn)")

        print(f"\n  Top 10 by avg spent:")
        by_avg = sorted(descs.items(), key=lambda x: sum(x[1]) / len(x[1]))
        for desc, amts in by_avg[:10]:
            avg = sum(amts) / len(amts)
            if avg >= 0:
                continue
            print(f"    {desc:<20} ${avg:>10,.2f}  ({len(amts)} txn)")

        print(f"\n  Top 10 by frequency:")
        by_freq = sorted(descs.items(), key=lambda x: -len(x[1]))
        for desc, amts in by_freq[:10]:
            print(f"    {desc:<20} {len(amts):>3} txn  ${sum(amts):>10,.2f}")


