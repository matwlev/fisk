            cat = input_with_completion("  Category []: ", categories).strip()
            notes = input("  Notes []: ").strip()
        except (EOFError, KeyboardInterrupt):
            print("\n  Cancelled.")
            return
        try:
            Decimal(amt)
        except InvalidOperation:
            print("  Invalid amount.")
            return
        status = "future" if date.fromisoformat(d) > date.today() else "pending"
        rows.append({
            "id": str(next_id(rows)),
            "date": d,
            "description": desc,
            "amount": amt,
            "category": cat,
            "status": status,
            "notes": notes,
        })
        write_ledger(self.name, rows)
        print("  Added.")

    def do_bulk(self, line):
        """bulk - add multiple transactions with the same date"""
        rows = read_ledger(self.name)
        if rows is None:
            return
        try:
            d = input(f"  Date [{date.today().isoformat()}]: ").strip() or date.today().isoformat()
            date.fromisoformat(d)
        except (EOFError, KeyboardInterrupt):
            print("\n  Cancelled.")
            return
        except ValueError:
            print("  Invalid date.")
            return
        status = "future" if date.fromisoformat(d) > date.today() else "pending"
        count = 0
        print("  Enter transactions (empty description to finish):")
        while True:
            descriptions = sorted(set(r["description"] for r in rows if r["status"] != "starting"))
            categories = sorted(set(r["category"] for r in rows if r["category"]))
            try:
                desc = input_with_completion("  Description: ", descriptions).strip()
                if not desc:
                    break
                amt = input("  Amount: ").strip()
                Decimal(amt)
                cat = input_with_completion("  Category []: ", categories).strip()
                notes = input("  Notes []: ").strip()
            except (EOFError, KeyboardInterrupt):
                print("\n  Stopping.")
                break
            except InvalidOperation:
                print("  Invalid amount, skipping.")
                continue
            rows.append({
                "id": str(next_id(rows)),
                "date": d,
                "description": desc,
                "amount": amt,
                "category": cat,
                "status": status,
                "notes": notes,
            })
            count += 1
            print("  ✓")
        if count:
            write_ledger(self.name, rows)
            print(f"  Added {count} transaction{'s' if count != 1 else ''}.")

    def do_edit(self, line):
        """edit <id> - edit a transaction"""
        tid = line.strip()
        if not tid:
            print("Usage: edit <id>")
            return
        rows = read_ledger(self.name)
        if rows is None:
            return
        row = next((r for r in rows if r["id"] == tid), None)
        if not row:
            print(f"  Transaction {tid} not found.")
            return
        descriptions = sorted(set(r["description"] for r in rows if r["status"] != "starting"))
        categories = sorted(set(r["category"] for r in rows if r["category"]))
        try:
            row["date"] = input(f"  Date [{row['date']}]: ").strip() or row["date"]
            row["description"] = input_with_completion(f"  Description [{row['description']}]: ", descriptions).strip() or row["description"]
            amt = input(f"  Amount [{row['amount']}]: ").strip()
            if amt:
                Decimal(amt)
                row["amount"] = amt
            row["category"] = input_with_completion(f"  Category [{row['category']}]: ", categories).strip() or row["category"]
            current_notes = row.get("notes", "")
            row["notes"] = input(f"  Notes [{current_notes}]: ").strip() or current_notes
        except (EOFError, KeyboardInterrupt):
            print("\n  Cancelled.")
            return
        except InvalidOperation:
            print("  Invalid amount.")
            return
        write_ledger(self.name, rows)
        print("  Updated.")

    def do_delete(self, line):
        """delete <id> [id...] - remove transactions"""
        ids = line.split()
        if not ids:
            print("Usage: delete <id> [id...]")
            return
        rows = read_ledger(self.name)
        if rows is None:
            return
        to_delete = [r for r in rows if r["id"] in set(ids)]
        if not to_delete:
            print("  No matching transactions.")
            return
        for r in to_delete:
            amt = Decimal(r["amount"])
            sign = f"-{abs(amt):.2f}" if amt < 0 else f"{amt:.2f}"
            print(f"  #{r['id']}  {r['date']}  {r['description']}  {sign}  {r['category']}")
        try:
            confirm = input("  Delete? [y/N]: ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            print("\n  Cancelled.")
            return
        if confirm != "y":
            print("  Cancelled.")
            return
        rows = [r for r in rows if r["id"] not in set(ids)]
        write_ledger(self.name, rows)
        print("  Deleted.")

    def do_clear(self, line):
        """clear <id> [id...] - mark transactions as cleared"""
        ids = line.split()
        if not ids:
            print("Usage: clear <id> [id...]")
            return
        rows = read_ledger(self.name)
        if rows is None:
            return
        for r in rows:
            if r["id"] in set(ids):
                r["status"] = "cleared"
        write_ledger(self.name, rows)
        print("  Cleared.")

    def do_details(self, line):
        """details <id> - show full details of a transaction"""
        tid = line.strip()
        if not tid:
            print("Usage: details <id>")
            return
        rows = read_ledger(self.name)
        if rows is None:
            return
        row = next((r for r in rows if r["id"] == tid), None)
        if not row:
            print(f"  Transaction {tid} not found.")
            return
        amt = Decimal(row["amount"])
        print(f"  ID:          {row['id']}")
        print(f"  Date:        {row['date']}")
        print(f"  Description: {row['description']}")
        print(f"  Amount:      {amt:.2f}")
        print(f"  Category:    {row['category'] or '—'}")
        print(f"  Status:      {row['status']}")
        print(f"  Notes:       {row.get('notes', '') or '—'}")

    def do_reconcile(self, line):
        """reconcile - walk through unreconciled transactions and verify balance"""
        rows = read_ledger(self.name)
        if rows is None:
            return
        try:
            stmt_balance = input("  Statement ending balance: ").strip()
            stmt_balance = Decimal(stmt_balance)
            stmt_date = input(f"  Statement date [{date.today().isoformat()}]: ").strip() or date.today().isoformat()
            stmt_date = date.fromisoformat(stmt_date)
        except (EOFError, KeyboardInterrupt):
            print("\n  Cancelled.")
            return
        except (InvalidOperation, ValueError):
            print("  Invalid input.")
            return

        # Find unreconciled transactions (pending or cleared) through statement date
        eligible = [r for r in sorted(rows, key=lambda x: (x["date"], int(x["id"])))
                    if r["status"] in ("pending", "cleared")
                    and date.fromisoformat(r["date"]) <= stmt_date]

        if not eligible:
            print("  No unreconciled transactions found.")
            return

        print(f"\n  {len(eligible)} unreconciled transaction(s) through {stmt_date}:\n")
        reconciled_ids = []
        for r in eligible:
            amt = Decimal(r["amount"])
            sign = f"-{abs(amt):.2f}" if amt < 0 else f"{amt:.2f}"
            try:
                resp = input(f"  #{r['id']}  {r['date']}  {r['description']}  {sign}  [Y/n/s]: ").strip().lower()
            except (EOFError, KeyboardInterrupt):
                print("\n  Stopping.")
                break
            if resp in ("", "y"):
                reconciled_ids.append(r["id"])
            elif resp == "n":
                print("    Flagged — skipping.")
            # 's' or anything else = skip silently

        # Compute reconciled balance
        previously_reconciled = sum(
            Decimal(r["amount"]) for r in rows if r["status"] == "reconciled"
        )
        newly_reconciled = sum(
            Decimal(r["amount"]) for r in rows if r["id"] in set(reconciled_ids)
        )
        # Include starting balance
        starting = sum(Decimal(r["amount"]) for r in rows if r["status"] == "starting")
        computed_balance = starting + previously_reconciled + newly_reconciled

        print(f"\n  Reconciled balance: {computed_balance:.2f}")
        print(f"  Statement balance:  {stmt_balance:.2f}", end="")
        if computed_balance == stmt_balance:
            print("  ✓ Balanced!")
        else:
            diff = computed_balance - stmt_balance
            print(f"  ✗ Difference: {diff:.2f}")
            try:
                proceed = input("  Balances don't match. Reconcile anyway? [y/N]: ").strip().lower()
            except (EOFError, KeyboardInterrupt):
                print("\n  Cancelled.")
                return
            if proceed != "y":
                print("  Cancelled. No changes made.")
                return

        # Apply
        for r in rows:
            if r["id"] in set(reconciled_ids):
                r["status"] = "reconciled"
        write_ledger(self.name, rows)
        print(f"  {len(reconciled_ids)} transaction(s) reconciled.")

    def do_sort(self, line):
        """sort - sort all by date; sort <id> <position> - move a transaction to a position"""
        rows = read_ledger(self.name)
        if rows is None:
            return
        parts = line.split()

        if len(parts) == 2:
            # Move a single transaction to a new position
            src_id, dest_pos = parts[0], parts[1]
            try:
                dest_pos = int(dest_pos)
            except ValueError:
                print("  Usage: sort <id> <position>")
                return
            row = next((r for r in rows if r["id"] == src_id), None)
            if not row:
                print(f"  Transaction {src_id} not found.")
                return
            rows.remove(row)
            idx = max(0, min(dest_pos - 1, len(rows)))
            rows.insert(idx, row)
            for i, r in enumerate(rows, 1):
                r["id"] = str(i)
            write_ledger(self.name, rows)
            print(f"  Moved to #{dest_pos}. IDs reassigned.")
            return

        if parts:
            print("  Usage: sort (sort all by date) or sort <id> <position>")
            return

        # Full sort by date
        print("  Current order:")
        for r in rows:
            amt = Decimal(r["amount"])
            sign = f"-{abs(amt):.2f}" if amt < 0 else f"{amt:.2f}"
            print(f"    #{r['id']}  {r['date']}  {r['description']}  {sign}")
        sorted_rows = sorted(rows, key=lambda x: (x["date"], int(x["id"])))
        print("\n  Sorted order:")
        for i, r in enumerate(sorted_rows, 1):
            amt = Decimal(r["amount"])
            sign = f"-{abs(amt):.2f}" if amt < 0 else f"{amt:.2f}"
            print(f"    #{i}  {r['date']}  {r['description']}  {sign}")
        try:
            confirm = input("\n  Apply this sort and reassign IDs? [y/N]: ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            print("\n  Cancelled.")
            return
        if confirm != "y":
            print("  Cancelled.")
            return
        for i, r in enumerate(sorted_rows, 1):
            r["id"] = str(i)
        write_ledger(self.name, sorted_rows)
        print("  Sorted.")

    def do_back(self, line):
        """Return to fisk prompt"""
        return True

    def do_quit(self, line):
        """Exit fisk entirely"""
        sys.exit(0)

    do_EOF = do_back


def cmd_import(args):
    """Import transactions from an external CSV file."""
    name = args.ledger
    if not ledger_path(name).exists():
        print(f"Ledger '{name}' not found. Create it first with: fisk create {name}")
        return
    src = Path(args.file)
    if not src.exists():
        print(f"File not found: {src}")
        return

    rows = read_ledger(name)
    with open(src, newline="", encoding="utf-8-sig") as f:
        reader = csv.DictReader(f)
        headers = reader.fieldnames
        print(f"  Source columns: {headers}")

        # Column mapping
        date_col = args.date_col or next((h for h in headers if h.lower().strip() == "date"), None)
        desc_col = args.desc_col or next((h for h in headers if h.lower().strip() == "description"), None)
        credit_col = args.credit_col or next((h for h in headers if h.lower().strip() == "credit"), None)
        debit_col = args.debit_col or next((h for h in headers if h.lower().strip() == "debit"), None)
        amount_col = args.amount_col or next((h for h in headers if h.lower().strip() == "amount"), None)
        category_col = args.category_col or next((h for h in headers if h.lower().strip() == "category"), None)
        cleared_col = args.cleared_col or next((h for h in headers if h.strip() in ("✓", "✔", "Cleared", "cleared")), None)

        if not date_col or not desc_col:
            print("  Could not auto-detect date/description columns. Use --date-col and --desc-col.")
            return
        if not credit_col and not debit_col and not amount_col:
            print("  Could not detect amount columns. Use --amount-col or --credit-col/--debit-col.")
            return

        count = 0
        date_fmt = args.date_format if hasattr(args, "date_format") else None
        for row in reader:
            d = row.get(date_col, "").strip()
            if not d:
                continue
            # Try to parse date
            parsed_date = None
            if date_fmt:
                try:
                    from datetime import datetime
                    parsed_date = datetime.strptime(d, date_fmt).date()
                except ValueError:
                    print(f"  Skipping row with unparseable date: {d}")
                    continue
            else:
                try:
                    parsed_date = date.fromisoformat(d)
                except ValueError:
                    for fmt in ("%m/%d/%Y", "%m/%d/%y", "%d/%m/%Y"):
                        try:
                            from datetime import datetime
                            parsed_date = datetime.strptime(d, fmt).date()
                            break
                        except ValueError:
                            continue
                    else:
                        print(f"  Skipping row with unparseable date: {d}")
                        continue

            desc = row.get(desc_col, "").strip()
            if not desc:
                continue

            # Compute amount
            if amount_col:
                amt_str = row.get(amount_col, "").strip().replace(",", "").replace("$", "")
                if not amt_str:
                    continue
                amt = Decimal(amt_str)
            else:
                credit_str = row.get(credit_col, "").strip().replace(",", "").replace("$", "") if credit_col else ""
                debit_str = row.get(debit_col, "").strip().replace(",", "").replace("$", "") if debit_col else ""
                if credit_str:
                    amt = Decimal(credit_str)
                elif debit_str:
                    amt = -abs(Decimal(debit_str))
                else:
                    continue

            cat = row.get(category_col, "").strip() if category_col else ""

            # Status from cleared column
            if cleared_col:
                cleared_val = row.get(cleared_col, "").strip()
                status = "cleared" if cleared_val else "pending"
            else:
                status = "pending"

            if parsed_date > date.today():
                status = "future"

            rows.append({
                "id": str(next_id(rows)),
                "date": parsed_date.isoformat(),
                "description": desc,
                "amount": str(amt),
                "category": cat,
                "status": status,
                "notes": "",
            })
            count += 1

    write_ledger(name, rows)
    print(f"  Imported {count} transactions into '{name}'.")


def cmd_sort_noninteractive(args):
    rows = read_ledger(args.ledger)
    if rows is None:
        return
    if args.id and args.position:
        row = next((r for r in rows if r["id"] == args.id), None)
        if not row:
            print(f"Transaction {args.id} not found.")
            return
        rows.remove(row)
        idx = max(0, min(args.position - 1, len(rows)))
        rows.insert(idx, row)
        for i, r in enumerate(rows, 1):
            r["id"] = str(i)
        write_ledger(args.ledger, rows)
        print(f"Moved to #{args.position}. IDs reassigned.")
    else:
        sorted_rows = sorted(rows, key=lambda x: (x["date"], int(x["id"])))
        for i, r in enumerate(sorted_rows, 1):
            r["id"] = str(i)
        write_ledger(args.ledger, sorted_rows)
        print("Sorted by date. IDs reassigned.")


# --- Main ---

def build_parser():
    parser = argparse.ArgumentParser(
        prog="fisk",
        description="Personal finance ledger. Run with no arguments for interactive mode.",
    )
    parser.add_argument("--version", action="version", version=f"fisk {VERSION}")
    sub = parser.add_subparsers(dest="command")

    p = sub.add_parser("create", help="Create a new ledger")
    p.add_argument("name", help="Ledger name")
    p.add_argument("--balance", default="0.00", help="Starting balance (default: 0.00)")
    p.add_argument("--path", help="Path for the CSV file")
    p.add_argument("--config", dest="config_file", help="Config file to register the ledger in")

    p = sub.add_parser("show", help="List ledgers or display a ledger")
    p.add_argument("ledger", nargs="?", help="Ledger to display (omit to list all)")
    p.add_argument("--start-date", help="Show transactions from this date (YYYY-MM-DD or 'today')")
    p.add_argument("--end-date", help="Show transactions through this date (default: today)")
    p.add_argument("--status", help="Filter by status: pending, cleared, all")
    p.add_argument("--sort", choices=["asc", "desc"], default="desc", help="Sort order: asc or desc (default: desc)")
    p.add_argument("--limit", type=int, help="Maximum number of transactions to display")
    p.add_argument("--amount", help="Filter by amount (e.g. '>=100', '<50', '=25.00')")

    p = sub.add_parser("forecast", help="Show ledger including future transactions")
    p.add_argument("ledger", help="Ledger to forecast")
    p.add_argument("-d", default=None, help="Target date or duration (YYYY-MM-DD, +2w, +30d, +3m)")
    p.add_argument("--start-date", help="Show transactions from this date")
    p.add_argument("--sort", choices=["asc", "desc"], default="desc", help="Sort order: asc or desc (default: desc)")
    p.add_argument("--limit", type=int, help="Maximum number of transactions to display")
    p.add_argument("--amount", help="Filter by amount (e.g. '>=100', '<50', '=25.00')")

    p = sub.add_parser("add", help="Add a transaction")
    p.add_argument("ledger", help="Ledger to add to")
    p.add_argument("--date", help="Transaction date (default: today)")
    p.add_argument("--desc", required=True, help="Description")
    p.add_argument("--amount", required=True, help="Amount (positive for credit, negative for debit)")
    p.add_argument("--category", default="", help="Category (optional)")
    p.add_argument("--notes", default="", help="Notes (optional)")

    p = sub.add_parser("clear", help="Mark transactions as cleared")
    p.add_argument("ledger", help="Ledger name")
    p.add_argument("ids", nargs="+", help="Transaction IDs to clear")

    p = sub.add_parser("delete", help="Delete transactions (with confirmation)")
    p.add_argument("ledger", help="Ledger name")
    p.add_argument("ids", nargs="+", help="Transaction IDs to delete")

    p = sub.add_parser("import", help="Import transactions from an external CSV")
    p.add_argument("ledger", help="Ledger to import into")
    p.add_argument("--file", required=True, help="Path to the source CSV file")
    p.add_argument("--date-col", help="Name of the date column")
    p.add_argument("--date-format", help="strptime format for dates (e.g. '%%a. %%m/%%d/%%y' for 'Fri. 06/05/26')")
    p.add_argument("--desc-col", help="Name of the description column")
    p.add_argument("--amount-col", help="Name of a single amount column (signed)")
    p.add_argument("--credit-col", help="Name of the credit column")
    p.add_argument("--debit-col", help="Name of the debit column")
    p.add_argument("--category-col", help="Name of the category column")
    p.add_argument("--cleared-col", help="Name of the cleared/checkmark column")

    p = sub.add_parser("sort", help="Sort transactions or move a transaction to a position")
    p.add_argument("ledger", help="Ledger name")
    p.add_argument("id", nargs="?", help="Transaction ID to move")
    p.add_argument("position", nargs="?", type=int, help="Target position")

    return parser


def main():
    if len(sys.argv) == 1:
        FiskRepl().cmdloop()
        return

    parser = build_parser()
    args = parser.parse_args()

    if args.command == "create":
        cmd_create(args)
    elif args.command == "show":
        cmd_show(args)
    elif args.command == "forecast":
        cmd_forecast(args)
    elif args.command == "add":
        cmd_add_noninteractive(args)
    elif args.command == "clear":
        cmd_clear_noninteractive(args)
    elif args.command == "delete":
        cmd_delete_noninteractive(args)
    elif args.command == "import":
        cmd_import(args)
    elif args.command == "sort":
        cmd_sort_noninteractive(args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
