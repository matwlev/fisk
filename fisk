class FiskRepl(cmd.Cmd):
    prompt = "fisk> "

    def __init__(self):
        super().__init__()
        self._last_show = None  # stores params for pagination

    def do_show(self, line):
        """show [ledger] [--start-date DATE] [--end-date DATE] [--status STATUS] [--source]"""
        parts = line.split()
        if not parts:
            show_dashboard()
            return
        if parts[0] == "next":
            self.do_next(" ".join(parts[1:]))
            return
        name = parts[0]
        rows = read_ledger(name)
        if rows is None:
            return
        # Parse inline flags
        defaults = get_default_flags()
        spec = {"--start-date": str, "--end-date": str, "--status": str, "--sort": str, "--limit": int, "--amount": str}
        flags, _ = parse_flags(parts[1:], spec)
        start = parse_date_or_relative(flags["--start-date"]) if "--start-date" in flags else None
        end = parse_date_or_relative(flags["--end-date"]) if "--end-date" in flags else date.today()
        status = flags.get("--status")
        sort_order = flags.get("--sort", defaults.get("--sort", "desc"))
        limit = flags.get("--limit", int(defaults["--limit"]) if "--limit" in defaults else None)
        amount_filter = parse_amount_filter(flags["--amount"]) if "--amount" in flags else None
        effective_limit = limit if limit is not None else 20
        self._last_show = {
            "name": name, "start": start, "end": end, "status": status,
            "sort_order": sort_order, "limit": effective_limit, "amount_filter": amount_filter,
            "offset": effective_limit,
        }
        format_table(rows, include_future=False, start_date=start, end_date=end, status_filter=status, sort_order=sort_order, limit=limit, amount_filter=amount_filter)

    def do_next(self, line):
        """show next [--limit N] - show the next page of transactions"""
        if not self._last_show:
            print("  No previous show command. Run 'show <ledger>' first.")
            return
        flags, _ = parse_flags(line.split(), {"--limit": int})
        limit = flags.get("--limit", self._last_show["limit"])
        p = self._last_show
        rows = read_ledger(p["name"])
        if rows is None:
            return
        format_table(rows, include_future=False, start_date=p["start"], end_date=p["end"],
                     status_filter=p["status"], sort_order=p["sort_order"], limit=limit,
                     amount_filter=p["amount_filter"], offset=p["offset"])
        p["offset"] += limit

    def do_forecast(self, line):
        """forecast <ledger> [-d DATE|DURATION]"""
        parts = line.split()
        if not parts:
            print("Usage: forecast <ledger> [-d DATE|DURATION]")
            return
        name = parts[0]
        rows = read_ledger(name)
        if rows is None:
            return
        defaults = get_default_flags()
        spec = {"-d": str, "--start-date": str, "--sort": str, "--limit": int, "--amount": str}
        flags, _ = parse_flags(parts[1:], spec)
        end = parse_date_or_relative(flags["-d"]) if "-d" in flags else date.today() + timedelta(days=30)
        start = parse_date_or_relative(flags["--start-date"]) if "--start-date" in flags else None
        sort_order = flags.get("--sort", defaults.get("--sort", "desc"))
        limit = flags.get("--limit", int(defaults["--limit"]) if "--limit" in defaults else None)
        amount_filter = parse_amount_filter(flags["--amount"]) if "--amount" in flags else None
        format_table(rows, include_future=True, start_date=start, end_date=end, sort_order=sort_order, limit=limit, amount_filter=amount_filter)

    def do_create(self, line):
        """create <name> [--balance AMOUNT] [--path PATH] [--config FILE]"""
        parts = line.split()
        if not parts:
            print("Usage: create <name> [--balance AMOUNT] [--path PATH] [--config FILE]")
            return
        name = parts[0]
        spec = {"--balance": str, "--path": str, "--config": str}
        flags, _ = parse_flags(parts[1:], spec)
        balance = flags.get("--balance", "0.00")
        csv_path = flags.get("--path")
        cfg_file = flags.get("--config")
        if csv_path:
            path = Path(csv_path).expanduser()
            path.parent.mkdir(parents=True, exist_ok=True)
        else:
            path = ledger_path(name)
        if path.exists():
            print(f"Ledger '{name}' already exists at {path}.")
            return
        rows = [{
            "id": "1",
            "date": date.today().isoformat(),
            "description": "Opening balance",
            "amount": balance,
            "category": "",
            "status": "starting",
            "notes": "",
        }]
        with open(path, "w", newline="") as f:
            w = csv.DictWriter(f, fieldnames=FIELDNAMES)
            w.writeheader()
            w.writerows(rows)
        add_ledger_to_config(name, str(path), config_file=cfg_file)
        print(f"Created: {path}")

    def do_use(self, line):
        """use <ledger> - enter interactive mode for a ledger (alias for 'ledgers')"""
        self.do_ledgers(line)

    def do_ledgers(self, line):
        """ledgers <name> - enter interactive mode for a ledger"""
        name = line.strip()
        if not name:
            for l in list_ledgers():
                print(f"  {l}")
            return
        if not ledger_path(name).exists():
            print(f"Ledger '{name}' not found.")
            return
        LedgerRepl(name).cmdloop()

    def do_bills(self, line):
        """bills [name] [--source] - enter bills context or show upcoming"""
        parts = line.split()
        if not parts:
            bill_files = list_bill_files()
            if not bill_files:
                print("  No bill files configured. Add a [bills] section to config.")
            else:
                for b in bill_files:
                    print(f"  {b}")
            return
        if parts[0] == "create":
            # bills create <name> [--path PATH]
            if len(parts) < 2:
                print("Usage: bills create <name> [--path PATH]")
                return
            name = parts[1]
            flags, _ = parse_flags(parts[2:], {"--path": str})
            if "--path" in flags:
                path = Path(flags["--path"]).expanduser()
                path.parent.mkdir(parents=True, exist_ok=True)
            else:
                path = get_ledger_dir() / f"{name}.csv"
            if path.exists():
                print(f"Bill file '{name}' already exists at {path}.")
                return
            with open(path, "w", newline="") as f:
                w = csv.DictWriter(f, fieldnames=BILL_FIELDNAMES)
                w.writeheader()
            add_bills_to_config(name, str(path))
            print(f"Created: {path}")
            return
        name = parts[0]
        if not bill_file_path(name).exists():
            print(f"Bill file '{name}' not found.")
            return
        BillsRepl(name).cmdloop()

    def do_quit(self, line):
        """Exit fisk"""
        return True

    def do_exit(self, line):
        """Exit fisk"""
        return True

    do_EOF = do_quit


