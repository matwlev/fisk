def input_with_completion(prompt, options):
    """Input with tab completion from a list of options."""
    def completer(text, state):
        matches = [o for o in options if o.lower().startswith(text.lower())]
        return matches[state] if state < len(matches) else None
    old_completer = readline.get_completer()
    old_delims = readline.get_completer_delims()
    readline.set_completer(completer)
    readline.set_completer_delims("\t\n")
    readline.parse_and_bind("tab: complete")
    try:
        return input(prompt)
    finally:
        readline.set_completer(old_completer)
        readline.set_completer_delims(old_delims)


def find_config():
    """Find config: --config flag, then ./fisk.config, then ~/.fisk/config."""
    for i, arg in enumerate(sys.argv):
        if arg in ("--config", "-c") and i + 1 < len(sys.argv):
            return Path(sys.argv[i + 1])
    if Path("./fisk.config").exists():
        return Path("./fisk.config")
    if (Path.home() / ".fisk" / "config").exists():
        return Path.home() / ".fisk" / "config"
    return None


def load_config():
    """Load config. Returns dict with 'ledgers' mapping, 'bills' mapping, and 'defaults' list."""
    config = {"ledgers": {}, "bills": {}, "defaults": []}
    config_file = find_config()
    if not config_file or not config_file.exists():
        return config
    section = ""
    for line in config_file.read_text().splitlines():
        line = line.split("#")[0].strip()
        if not line:
            continue
        if line.startswith("[") and line.endswith("]"):
            section = line[1:-1]
            continue
        if section == "ledgers":
            parts = line.split(None, 1)
            if len(parts) == 2:
                config["ledgers"][parts[0]] = str(Path(parts[1]).expanduser())
        elif section == "bills":
            parts = line.split(None, 1)
            if len(parts) == 2:
                config["bills"][parts[0]] = str(Path(parts[1]).expanduser())
        elif section == "defaults":
            config["defaults"].append(line)
    return config


_config = None


def get_config():
    global _config
    if _config is None:
        _config = load_config()
    return _config


def get_ledger_dir():
    """Directory for ledgers not explicitly mapped in config.
    Uses config file's parent dir if a local config is found."""
    env = os.environ.get("FISK_DIR")
    if env:
        d = Path(env)
    else:
        config_file = find_config()
        if config_file:
            d = config_file.parent
        else:
            d = DEFAULT_DIR
    d.mkdir(parents=True, exist_ok=True)
    return d


def ledger_path(name):
    config = get_config()
    if name in config["ledgers"]:
        return Path(config["ledgers"][name])
    return get_ledger_dir() / f"{name}.csv"


def list_ledgers():
    config = get_config()
    names = set(config["ledgers"].keys())
    bill_names = set(config.get("bills", {}).keys())
    bill_paths = set(Path(p).resolve() for p in config.get("bills", {}).values())
    d = get_ledger_dir()
    if d.exists():
        for p in d.glob("*.csv"):
            if p.resolve() not in bill_paths and p.stem not in bill_names:
                names.update([p.stem])
    return sorted(names)


def add_ledger_to_config(name, path, config_file=None):
    """Add a ledger entry to the active config file."""
    if config_file is None:
        config_file = find_config()
    if not config_file or not Path(config_file).exists():
        return
    config_file = Path(config_file)
    abs_path = str(Path(path).resolve())
    lines = config_file.read_text().splitlines()
    # Find [ledgers] section and insert after it
    inserted = False
    for i, line in enumerate(lines):
        if line.strip() == "[ledgers]":
            # Insert after the section header (and any existing entries)
            j = i + 1
            while j < len(lines) and not lines[j].strip().startswith("[") and lines[j].strip() != "":
                j += 1
            lines.insert(j, f"{name}  {abs_path}")
            inserted = True
            break
    if not inserted:
        lines.append("\n[ledgers]")
        lines.append(f"{name}  {abs_path}")
    config_file.write_text("\n".join(lines) + "\n")
    # Refresh cached config
    global _config
    _config = None


def add_bills_to_config(name, path, config_file=None):
    """Add a bills entry to the active config file."""
    if config_file is None:
        config_file = find_config()
    if not config_file or not Path(config_file).exists():
        return
    config_file = Path(config_file)
    abs_path = str(Path(path).resolve())
    lines = config_file.read_text().splitlines()
    inserted = False
    for i, line in enumerate(lines):
        if line.strip() == "[bills]":
            j = i + 1
            while j < len(lines) and not lines[j].strip().startswith("[") and lines[j].strip() != "":
                j += 1
            lines.insert(j, f"{name}  {abs_path}")
            inserted = True
            break
    if not inserted:
        lines.append("")
        lines.append("[bills]")
        lines.append(f"{name}  {abs_path}")
    config_file.write_text("\n".join(lines) + "\n")
    global _config
    _config = None


def read_ledger(name):
    path = ledger_path(name)
    if not path.exists():
        print(f"Ledger '{name}' not found.")
        return None
    with open(path, newline="") as f:
        rows = list(csv.DictReader(f))
        for r in rows:
            if "notes" not in r:
                r["notes"] = ""
        return rows


def write_ledger(name, rows):
    path = ledger_path(name)
    with open(path, "w", newline="") as f:
        w = csv.DictWriter(f, fieldnames=FIELDNAMES)
        w.writeheader()
        w.writerows(rows)


# --- Bills ---

def list_bill_files():
    config = get_config()
    return sorted(config["bills"].keys())


def bill_file_path(name):
    config = get_config()
    if name in config["bills"]:
        return Path(config["bills"][name])
    return get_ledger_dir() / f"{name}.csv"


def read_bills(name):
    path = bill_file_path(name)
    if not path.exists():
        print(f"Bill file '{name}' not found.")
        return None
    with open(path, newline="") as f:
        rows = list(csv.DictReader(f))
        for r in rows:
            for field in BILL_FIELDNAMES:
                if field not in r:
                    r[field] = ""
        return rows


def write_bills(name, rows):
    path = bill_file_path(name)
    with open(path, "w", newline="") as f:
        w = csv.DictWriter(f, fieldnames=BILL_FIELDNAMES)
        w.writeheader()
        w.writerows(rows)


def instance_file_path(name):
    """Path to the instances CSV for a bill file."""
    bp = bill_file_path(name)
    return bp.parent / f"{bp.stem}_instances.csv"


def read_instances(name):
    """Read instances for a bill file. Returns empty list if file doesn't exist."""
    path = instance_file_path(name)
    if not path.exists():
        return []
    with open(path, newline="") as f:
        rows = list(csv.DictReader(f))
        for r in rows:
            for field in INSTANCE_FIELDNAMES:
                if field not in r:
                    r[field] = ""
        return rows


def write_instances(name, rows):
    path = instance_file_path(name)
    with open(path, "w", newline="") as f:
        w = csv.DictWriter(f, fieldnames=INSTANCE_FIELDNAMES)
        w.writeheader()
        w.writerows(rows)


def next_instance_id(rows):
    if not rows:
        return 1
    return max(int(r["id"]) for r in rows) + 1


def generate_predicted_instances(name, window_days=90):
    """Generate predicted instances for all bills in a file, merged with existing instances.
    Returns combined list of existing + predicted instances within window."""
    bills = read_bills(name)
    if not bills:
        return []
    instances = read_instances(name)
    today = date.today()
    end = today + timedelta(days=window_days)

    # Index existing instance dates per bill for fuzzy dedup
    existing_dates = {}
    for r in instances:
        existing_dates.setdefault(r["bill_id"], []).append(date.fromisoformat(r["due_date"]))

    predicted = []
    for bill in bills:
        if not bill["start_date"]:
            continue
        # Determine start: after latest instance or paid_through for this bill
        bill_instances = [i for i in instances if i["bill_id"] == bill["id"]]
        latest_date = None
        for inst in bill_instances:
            d = inst.get("due_date")
            if d:
                if latest_date is None or d > latest_date:
                    latest_date = d
        paid_through = date.fromisoformat(bill["paid_through"]) if bill["paid_through"] else None
        if latest_date:
            start = date.fromisoformat(latest_date) + timedelta(days=1)
        elif paid_through:
            start = paid_through + timedelta(days=1)
        else:
            start = date.fromisoformat(bill["start_date"])
        # Clamp start to not generate ancient predictions
        earliest = today - timedelta(days=window_days)
        if start < earliest:
            start = earliest
        dates = generate_due_dates(bill, start, end)
        amt, is_estimate = get_bill_amount(bill)
        bill_existing = existing_dates.get(bill["id"], [])
        for d in dates:
            # Suppress if there's already a materialized instance within ±7 days
            if any(abs((d - ed).days) <= 7 for ed in bill_existing):
                continue
            predicted.append({
                "id": "",  # not persisted
                "bill_id": bill["id"],
                "due_date": d.isoformat(),
                "amount": f"~{amt:.2f}" if amt and is_estimate else (str(amt) if amt else ""),
                "paid_date": "",
                "status": "predicted",
                "ledger": "",
                "transaction_id": "",
                })
    return instances + predicted


def get_instance_for_bill(name, bill_id, due_date_str=None):
    """Find the next actionable instance for a bill. If due_date_str given, find that specific one."""
    instances = read_instances(name)
    bill_instances = [i for i in instances if i["bill_id"] == bill_id]
    if due_date_str:
        return next((i for i in bill_instances if i["due_date"] == due_date_str), None)
    # Find first non-paid instance
    unpaid = [i for i in bill_instances if i["status"] in ("unpaid", "predicted")]
    if unpaid:
        unpaid.sort(key=lambda x: x["due_date"])
        return unpaid[0]
    return None


def next_bill_id(rows):
    if not rows:
        return 1
    return max(int(r["id"]) for r in rows) + 1


def add_month(d, months):
    """Add months to a date, clamping day to valid range."""
    m = d.month - 1 + months
    year = d.year + m // 12
    month = m % 12 + 1
    import calendar
    day = min(d.day, calendar.monthrange(year, month)[1])
    return date(year, month, day)


def generate_due_dates(bill, start, end):
    """Generate due dates for a bill within [start, end]."""
    freq = bill["frequency"]
    start_date = date.fromisoformat(bill["start_date"])
    end_date = date.fromisoformat(bill["end_date"]) if bill["end_date"] else None
    due_day = int(bill["due_day"]) if bill["due_day"] else None

    dates = []
    # Interval-based frequencies (e.g. "14d", "30d")
    m = re.match(r"^(\d+)d$", freq)
    if m:
        interval = int(m.group(1))
        current = start_date
        while current <= end:
            if current >= start and (not end_date or current <= end_date):
                dates.append(current)
            current += timedelta(days=interval)
        return dates

    # Calendar-based frequencies
    month_intervals = {
        "monthly": 1, "bimonthly": 2, "quarterly": 3,
        "semiannual": 6, "annual": 12,
    }
    interval = month_intervals.get(freq)
    if not interval:
        return dates

    import calendar
    # Generate from start_date forward
    current = start_date
    if due_day:
        # Anchor to due_day in the start month
        day = min(due_day, calendar.monthrange(current.year, current.month)[1])
        current = date(current.year, current.month, day)
        if current < start_date:
            current = add_month(current, interval)
            day = min(due_day, calendar.monthrange(current.year, current.month)[1])
            current = date(current.year, current.month, day)

    while current <= end:
        if current >= start and (not end_date or current <= end_date):
            dates.append(current)
        current = add_month(current, interval)
        if due_day:
            import calendar
            day = min(due_day, calendar.monthrange(current.year, current.month)[1])
            current = date(current.year, current.month, day)
    return dates


def get_next_due(bill):
    """Get next unpaid due date for a bill."""
    if not bill["start_date"]:
        return None
    paid_through = date.fromisoformat(bill["paid_through"]) if bill["paid_through"] else None
    start = paid_through + timedelta(days=1) if paid_through else date.fromisoformat(bill["start_date"])
    end = date.today() + timedelta(days=365)
    dates = generate_due_dates(bill, start, end)
    return dates[0] if dates else None


def get_upcoming_bills(window_days=30):
    """Get all upcoming bills across all bill files within window."""
    upcoming = []
    today = date.today()
    end = today + timedelta(days=window_days)
    for bf_name in list_bill_files():
        bills = read_bills(bf_name)
        if not bills:
            continue
        bill_map = {b["id"]: b for b in bills}
        all_instances = generate_predicted_instances(bf_name, window_days=window_days)
        for inst in all_instances:
            if inst["status"] == "paid":
                continue
            due = date.fromisoformat(inst["due_date"])
            if due > end:
                continue
            bill = bill_map.get(inst["bill_id"])
            if not bill:
                continue
            amt = None
            is_estimate = False
            if inst["amount"]:
                if inst["amount"].startswith("~"):
                    amt = Decimal(inst["amount"][1:])
                    is_estimate = True
                else:
                    amt = Decimal(inst["amount"])
            else:
                amt, is_estimate = get_bill_amount(bill)
            upcoming.append({
                "name": bill["name"],
                "amount": amt,
                "is_estimate": is_estimate,
                "due": due,
                "status": inst["status"],
                "source": bf_name,
            })
    upcoming.sort(key=lambda x: x["due"])
    _clear_ledger_cache()
    return upcoming


_ledger_cache = {}


def _get_cached_ledger(name):
    """Read a ledger with caching to avoid repeated disk reads during bill scanning."""
    if name not in _ledger_cache:
        _ledger_cache[name] = read_ledger(name)
    return _ledger_cache[name]


def _clear_ledger_cache():
    _ledger_cache.clear()


def find_likely_match(bill, due_date):
    """Search ledgers for a transaction that likely matches this bill payment."""
    target_amt = Decimal(bill["amount"]) if bill["amount"] else None
    target_name = bill["name"].lower()
    window = timedelta(days=15)
    best = None
    for ledger_name in list_ledgers():
        rows = _get_cached_ledger(ledger_name)
        if not rows:
            continue
        for r in rows:
            desc = r["description"].lower()
            if target_name not in desc and desc not in target_name:
                continue
            rd = date.fromisoformat(r["date"])
            if abs((rd - due_date).days) > window.days:
                continue
            amt = abs(Decimal(r["amount"]))
            if target_amt is None or amt == target_amt or abs(amt - target_amt) <= target_amt * Decimal("0.1"):
                if best is None or abs((rd - due_date).days) < abs((best["rd"] - due_date).days):
                    best = {"ledger": ledger_name, "id": r["id"], "desc": r["description"], "date": r["date"], "rd": rd}
    if best:
        return f"{best['ledger']} #{best['id']} \"{best['desc']}\" {best['date']}"
    return None


def estimate_bill_amount(bill):
    """Estimate a bill's amount from the last 6 matching ledger transactions."""
    target_name = bill["name"].lower()
    matches = []
    for ledger_name in list_ledgers():
        rows = _get_cached_ledger(ledger_name)
        if not rows:
            continue
        for r in rows:
            desc = r["description"].lower()
            if target_name in desc or desc in target_name:
                matches.append((r["date"], abs(Decimal(r["amount"]))))
    if not matches:
        return None
    matches.sort(key=lambda x: x[0], reverse=True)
    recent = [amt for _, amt in matches[:6]]
    return sum(recent) / len(recent)


def get_bill_amount(bill):
    """Get bill amount or estimate. Returns (amount, is_estimate) tuple."""
    if bill["amount"]:
        return Decimal(bill["amount"]), False
    est = estimate_bill_amount(bill)
    if est:
        return est, True
    return None, True


def find_matching_transaction(bill, due_date, ledger_name):
    """Find an existing transaction in a specific ledger that matches this bill payment."""
    target_name = bill["name"].lower()
    target_amt = Decimal(bill["amount"]) if bill["amount"] else None
    window = timedelta(days=15)
    rows = read_ledger(ledger_name)
    if not rows:
        return None
    best = None
    for r in rows:
        desc = r["description"].lower()
        if target_name not in desc and desc not in target_name:
            continue
        rd = date.fromisoformat(r["date"])
        if abs((rd - due_date).days) > window.days:
            continue
        amt = abs(Decimal(r["amount"]))
        if target_amt and not (amt == target_amt or abs(amt - target_amt) <= target_amt * Decimal("0.1")):
            continue
        if best is None or abs((rd - due_date).days) < abs(best["days"]):
            best = {"id": r["id"], "desc": r["description"], "date": r["date"], "amount": r["amount"], "status": r["status"], "days": (rd - due_date).days}
    if best:
        return {"id": best["id"], "desc": best["desc"], "date": best["date"], "amount": best["amount"], "status": best["status"]}
    return None


def next_id(rows):
    if not rows:
        return 1
    return max(int(r["id"]) for r in rows) + 1


def parse_date_or_relative(val):
    """Parse YYYY-MM-DD, 'today', or relative like +2w, +30d, +3m."""
    if val == "today":
        return date.today()
    m = re.match(r"^\+(\d+)([dwm])$", val)
    if m:
        n, unit = int(m.group(1)), m.group(2)
        if unit == "d":
            return date.today() + timedelta(days=n)
        elif unit == "w":
            return date.today() + timedelta(weeks=n)
        elif unit == "m":
            return add_month(date.today(), n)
    return date.fromisoformat(val)


def parse_amount_filter(val):
    """Parse an amount filter like '>=100', '<50', '=25.00'."""
    m = re.match(r"^(>=|<=|>|<|=)(.+)$", val)
    if not m:
        return None
    op, amt = m.group(1), m.group(2)
    try:
        threshold = Decimal(amt)
    except InvalidOperation:
        return None
    return (op, threshold)


def parse_flags(parts, spec):
    """Parse flags from a list of tokens. spec maps flag names to types (str, int, bool).
    Returns (dict of flag values, list of positional args)."""
    flags = {}
    positional = []
    i = 0
    while i < len(parts):
        if parts[i] in spec:
            typ = spec[parts[i]]
            if typ is bool:
                flags[parts[i]] = True
                i += 1
            elif i + 1 < len(parts):
                flags[parts[i]] = typ(parts[i + 1])
                i += 2
            else:
                i += 1
        else:
            positional.append(parts[i])
            i += 1
    return flags, positional


def validate_date(val):
    """Validate a date string. Returns the date string if valid, None otherwise."""
    try:
        if val == "today" or re.match(r"^\+\d+[dwm]$", val):
            parse_date_or_relative(val)
            return val
        date.fromisoformat(val)
        return val
    except (ValueError, TypeError):
        return None


def show_dashboard(show_source=False):
    """Display ledger list and upcoming bills. Used by both REPL and CLI."""
    ledgers = list_ledgers()
    if ledgers:
        print("  Ledgers")
        print(f"  {'─'*16}")
        for l in ledgers:
            print(f"  {l}")
    else:
        print("  No ledgers. Use 'create <name>' to create one.")
    bill_files = list_bill_files()
    if bill_files:
        upcoming = get_upcoming_bills(30)
        due_bills = [b for b in upcoming if b["status"] in ("unpaid", "predicted")]
        if due_bills:
            print(f"\n  Bills (next 30 days)")
            print(f"  {'─'*56}")
            for b in due_bills:
                due_str = b["due"].strftime("%b %d")
                source_str = f"  [{b['source']}]" if show_source else ""
                if b["amount"] is not None:
                    prefix = "~$" if b["is_estimate"] else " $"
                    print(f"  {b['name']:<18} {prefix}{b['amount']:>9,.2f}  due {due_str:<8} {b['status']}{source_str}")
                else:
                    print(f"  {b['name']:<18} {'':>11}  due {due_str:<8} {b['status']}{source_str}")


def pay_bill(bill_file, bill_name, add_ledger=None, paid_date=None):
    """Shared pay logic for both REPL and CLI. Returns True on success."""
    bills = read_bills(bill_file)
    if not bills:
        return False
    bill = next((b for b in bills if b["name"].lower() == bill_name.lower()), None)
    if not bill:
        print(f"  Bill '{bill_name}' not found.")
        return False
    # Find the instance to pay (unpaid first, then predicted)
    instances = read_instances(bill_file)
    bill_insts = [i for i in instances if i["bill_id"] == bill["id"] and i["status"] == "unpaid"]
    bill_insts.sort(key=lambda x: x["due_date"])
    instance = bill_insts[0] if bill_insts else None
    if not instance:
        # No received instance — use next predicted due
        next_due = get_next_due(bill)
        if not next_due:
            print(f"  No upcoming due date for '{bill_name}'.")
            return False
    else:
        next_due = date.fromisoformat(instance["due_date"])
    pay_d = paid_date or date.today().isoformat()
    if not paid_date:
        try:
            pay_d = input(f"  Paid date [{date.today().isoformat()}]: ").strip() or date.today().isoformat()
        except (EOFError, KeyboardInterrupt):
            print("\n  Cancelled.")
            return False
        if not validate_date(pay_d):
            print("  Invalid date.")
            return False
        pay_d = parse_date_or_relative(pay_d).isoformat()
    # Determine amount
    if instance and instance["amount"] and not instance["amount"].startswith("~"):
        amt = Decimal(instance["amount"])
    else:
        amt, is_estimate = get_bill_amount(bill)
        if amt is None or (instance and instance["amount"].startswith("~")) or (not instance and is_estimate):
            try:
                default = f"~{amt:.2f}" if amt else ""
                amt_input = input(f"  Amount [{default}]: ").strip()
                if amt_input:
                    amt = Decimal(amt_input)
                elif amt is None:
                    print("  Amount required.")
                    return False
            except (EOFError, KeyboardInterrupt, InvalidOperation):
                print("\n  Cancelled.")
                return False
    # Ledger transaction
    txn_id = ""
    ledger_name = ""
    if add_ledger:
        ledger_rows = read_ledger(add_ledger)
        if ledger_rows is None:
            print(f"  Ledger '{add_ledger}' not found. Bill not marked paid.")
            return False
        existing = find_matching_transaction(bill, next_due, add_ledger)
        if existing:
            txn_id = existing["id"]
            ledger_name = add_ledger
            for r in ledger_rows:
                if r["id"] == existing["id"] and r["status"] == "future":
                    r["status"] = "pending"
                    # Add back-reference in notes
                    r["notes"] = f"bill:{bill_file}:{bill['id']}"
                    write_ledger(add_ledger, ledger_rows)
                    print(f"  ✓ {add_ledger} #{r['id']} marked pending")
                    break
            else:
                # Update notes on existing match
                for r in ledger_rows:
                    if r["id"] == existing["id"]:
                        if not r["notes"]:
                            r["notes"] = f"bill:{bill_file}:{bill['id']}"
                            write_ledger(add_ledger, ledger_rows)
                        break
                print(f"  ✓ Matched {add_ledger} #{existing['id']}")
        else:
            new_id = str(next_id(ledger_rows))
            ledger_rows.append({
                "id": new_id,
                "date": pay_d,
                "description": bill["name"],
                "amount": str(-abs(amt)),
                "category": bill["category"],
                "status": "pending",
                "notes": f"bill:{bill_file}:{bill['id']}",
            })
            write_ledger(add_ledger, ledger_rows)
            txn_id = new_id
            ledger_name = add_ledger
            print(f"  ✓ Transaction added to {add_ledger} (#{new_id})")
    # Create or update instance
    if instance:
        instance["amount"] = str(amt)
        instance["paid_date"] = pay_d
        instance["status"] = "paid"
        instance["ledger"] = ledger_name
        instance["transaction_id"] = txn_id
    else:
        instances.append({
            "id": str(next_instance_id(instances)),
            "bill_id": bill["id"],
            "due_date": next_due.isoformat(),
            "amount": str(amt),
            "paid_date": pay_d,
            "status": "paid",
            "ledger": ledger_name,
            "transaction_id": txn_id,
        })
    write_instances(bill_file, instances)
    # Update paid_through on the bill
    bill["paid_through"] = next_due.isoformat()
    write_bills(bill_file, bills)
    print(f"  ✓ {bill['name']} paid {pay_d} (due {next_due})")
    return True


def get_default_flags():
    """Parse [defaults] section from config into a dict."""
    config = get_config()
    flags = {}
    for line in config.get("defaults", []):
        parts = line.split(None, 1)
        if len(parts) == 2:
            flags[parts[0]] = parts[1]
        elif len(parts) == 1:
            flags[parts[0]] = True
    return flags


def format_table(rows, include_future=False, start_date=None, end_date=None, status_filter=None, sort_order="desc", limit=None, amount_filter=None, offset=0):
    """Format rows into a table with debit/credit/balance columns. Returns total count for pagination."""
    filtered = []
    for r in sorted(rows, key=lambda x: (x["date"], int(x["id"]))):
        s = r["status"]
        if not include_future and s == "future":
            continue
        if status_filter and s != status_filter and status_filter != "all":
            continue
        rd = date.fromisoformat(r["date"])
        if start_date and rd < start_date:
            continue
        if end_date and rd > end_date:
            continue
        if amount_filter:
            op, threshold = amount_filter
            amt = abs(Decimal(r["amount"]))
            if op == ">=" and not (amt >= threshold):
                continue
            elif op == "<=" and not (amt <= threshold):
                continue
            elif op == ">" and not (amt > threshold):
                continue
            elif op == "<" and not (amt < threshold):
                continue
            elif op == "=" and not (amt == threshold):
                continue
        filtered.append(r)

    if not filtered:
        print("  No transactions.")
        return

    # Compute running balance from ALL rows up to each displayed row
    all_sorted = sorted(rows, key=lambda x: (x["date"], int(x["id"])))
    balance = Decimal("0")
    balances = {}
    for r in all_sorted:
        if not include_future and r["status"] == "future":
            continue
        balance += Decimal(r["amount"])
        balances[r["id"]] = balance

    # For forecast, include future in balance calc
    if include_future:
        balance = Decimal("0")
        balances = {}
        for r in all_sorted:
            balance += Decimal(r["amount"])
            balances[r["id"]] = balance

    if sort_order == "desc":
        filtered = list(reversed(filtered))

    total = len(filtered)
    if limit is None:
        limit = 20
    if limit == 0:
        hidden = 0
    else:
        filtered = filtered[offset:offset + limit]
        hidden = total - offset - len(filtered)

    hdr = f"  {'#':>4}  {'Date':<10}  {'Description':<20}  {'Debit':>10}  {'Credit':>10}  {'Balance':>11}  {'Status':<10}"
    print(hdr)
    print(f"  {'─'*4}  {'─'*10}  {'─'*20}  {'─'*10}  {'─'*10}  {'─'*11}  {'─'*10}")
    for r in filtered:
        amt = Decimal(r["amount"])
        debit = "$" + f"{abs(amt):,.2f}".rjust(9) if amt < 0 else " " * 10
        credit = "$" + f"{amt:,.2f}".rjust(9) if amt > 0 else " " * 10
        bal = balances.get(r["id"], Decimal("0"))
        bal_str = "$" + f"{bal:,.2f}".rjust(10)
        st = r["status"] if r["status"] != "starting" else ""
        desc = r["description"][:19] + "…" if len(r["description"]) > 20 else r["description"]
        print(f"  {r['id']:>4}  {r['date']:<10}  {desc:<20}  {debit}  {credit}  {bal_str}  {st}")
    if hidden > 0:
        print(f"  ...{hidden} more transaction{'s' if hidden != 1 else ''}. Use 'show next' or --limit to see more.")
    return total


