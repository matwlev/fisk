            return
        bills.append({
            "id": str(next_bill_id(bills)),
            "name": name,
            "amount": amount,
            "category": category,
            "frequency": frequency,
            "due_day": due_day,
            "start_date": start_date,
            "end_date": end_date,
            "paid_through": "",
        })
        write_bills(self.name, bills)
        print("  Added.")

    def do_receive(self, line):
        """receive <name> [--due DATE] [--amount AMT] - record a bill statement received"""
        parts = line.split()
        if not parts:
            print("Usage: receive <bill name> [--due DATE] [--amount AMT]")
            return
        flags, positional = parse_flags(parts, {"--due": str, "--amount": str})
        bill_name = " ".join(positional)
        bills = read_bills(self.name)
        if not bills:
            return
        bill = next((b for b in bills if b["name"].lower() == bill_name.lower()), None)
        if not bill:
            print(f"  Bill '{bill_name}' not found.")
            return
        # Get or prompt for due date
        due_str = flags.get("--due")
        if not due_str:
            next_due = get_next_due(bill)
            default = next_due.isoformat() if next_due else ""
            try:
                due_str = input(f"  Due date [{default}]: ").strip() or default
            except (EOFError, KeyboardInterrupt):
                print("\n  Cancelled.")
                return
        if not due_str or not validate_date(due_str):
            print("  Invalid date.")
            return
        due_str = parse_date_or_relative(due_str).isoformat()
        # Get or prompt for amount
        amt_str = flags.get("--amount")
        if not amt_str:
            est, is_estimate = get_bill_amount(bill)
            default_amt = f"~{est:.2f}" if est and is_estimate else (f"{est:.2f}" if est else "")
            try:
                amt_str = input(f"  Amount [{default_amt}]: ").strip() or (str(est) if est else "")
            except (EOFError, KeyboardInterrupt):
                print("\n  Cancelled.")
                return
        if amt_str:
            try:
                Decimal(amt_str)
            except InvalidOperation:
                print("  Invalid amount.")
                return
        # Check if instance already exists for this due date
        instances = read_instances(self.name)
        existing = next((i for i in instances if i["bill_id"] == bill["id"] and i["due_date"] == due_str), None)
        if existing:
            if existing["status"] == "paid":
                print(f"  Already paid on {existing['paid_date']}.")
                return
            existing["amount"] = amt_str
            existing["status"] = "unpaid"
        else:
            instances.append({
                "id": str(next_instance_id(instances)),
                "bill_id": bill["id"],
                "due_date": due_str,
                "amount": amt_str,
                "paid_date": "",
                "status": "unpaid",
                "ledger": "",
                "transaction_id": "",
            })
        write_instances(self.name, instances)
        print(f"  ✓ {bill['name']} due {due_str} — ${Decimal(amt_str):,.2f}" if amt_str else f"  ✓ {bill['name']} due {due_str}")

    def do_pay(self, line):
        """pay <name> [--add <ledger>] [--date DATE] - mark a bill as paid"""
        parts = line.split()
        if not parts:
            print("Usage: pay <bill name> [--add <ledger>] [--date DATE]")
            return
        flags, positional = parse_flags(parts, {"--add": str, "--date": str})
        bill_name = " ".join(positional)
        pay_bill(self.name, bill_name, add_ledger=flags.get("--add"), paid_date=flags.get("--date"))

    def do_edit(self, line):
        """edit <id> - edit a bill"""
