            bill["frequency"] = input(f"  Frequency [{bill['frequency']}]: ").strip() or bill["frequency"]
            bill["due_day"] = input(f"  Due day [{bill['due_day']}]: ").strip() or bill["due_day"]
            bill["start_date"] = input(f"  Start date [{bill['start_date']}]: ").strip() or bill["start_date"]
