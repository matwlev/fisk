DEFAULT_DIR = Path.home() / "fisk"
FIELDNAMES = ["id", "date", "description", "amount", "category", "status", "notes"]


def input_with_completion(prompt, options):
    """Input with tab completion from a list of options."""
    def completer(text, state):
        matches = [o for o in options if o.lower().startswith(text.lower())]
        return matches[state] if state < len(matches) else None
    old_completer = readline.get_completer()
    old_delims = readline.get_completer_delims()
    readline.set_completer(completer)
    readline.set_completer_delims("\t\n")
    readline.parse_and_bind("tab: complete")
    try:
        return input(prompt)
    finally:
        readline.set_completer(old_completer)
        readline.set_completer_delims(old_delims)


def find_config():
    """Find config: --config flag, then ./fisk.config, then ~/.fisk/config."""
    for i, arg in enumerate(sys.argv):
        if arg in ("--config", "-c") and i + 1 < len(sys.argv):
            return Path(sys.argv[i + 1])
    if Path("./fisk.config").exists():
        return Path("./fisk.config")
    if (Path.home() / ".fisk" / "config").exists():
        return Path.home() / ".fisk" / "config"
    return None


def load_config():
    """Load config. Returns dict with 'ledgers' mapping and 'defaults' list."""
    config = {"ledgers": {}, "defaults": []}
    config_file = find_config()
    if not config_file or not config_file.exists():
        return config
    section = ""
    for line in config_file.read_text().splitlines():
        line = line.split("#")[0].strip()
        if not line:
            continue
        if line.startswith("[") and line.endswith("]"):
            section = line[1:-1]
            continue
        if section == "ledgers":
            parts = line.split(None, 1)
            if len(parts) == 2:
                config["ledgers"][parts[0]] = str(Path(parts[1]).expanduser())
        elif section == "defaults":
            config["defaults"].append(line)
    return config


_config = None


def get_config():
    global _config
    if _config is None:
        _config = load_config()
    return _config


def get_ledger_dir():
    """Directory for ledgers not explicitly mapped in config.
    Uses config file's parent dir if a local config is found."""
    env = os.environ.get("FISK_DIR")
    if env:
        d = Path(env)
    else:
        config_file = find_config()
        if config_file:
            d = config_file.parent
        else:
            d = DEFAULT_DIR
    d.mkdir(parents=True, exist_ok=True)
    return d


def ledger_path(name):
    config = get_config()
    if name in config["ledgers"]:
        return Path(config["ledgers"][name])
    return get_ledger_dir() / f"{name}.csv"


def list_ledgers():
    config = get_config()
    names = set(config["ledgers"].keys())
    d = get_ledger_dir()
    if d.exists():
        names.update(p.stem for p in d.glob("*.csv"))
    return sorted(names)


def add_ledger_to_config(name, path, config_file=None):
    """Add a ledger entry to the active config file."""
    if config_file is None:
        config_file = find_config()
    if not config_file or not Path(config_file).exists():
        return
    config_file = Path(config_file)
    abs_path = str(Path(path).resolve())
    lines = config_file.read_text().splitlines()
    # Find [ledgers] section and insert after it
    inserted = False
    for i, line in enumerate(lines):
        if line.strip() == "[ledgers]":
            # Insert after the section header (and any existing entries)
            j = i + 1
            while j < len(lines) and not lines[j].strip().startswith("[") and lines[j].strip() != "":
                j += 1
            lines.insert(j, f"{name}  {abs_path}")
            inserted = True
            break
    if not inserted:
        lines.append("\n[ledgers]")
        lines.append(f"{name}  {abs_path}")
    config_file.write_text("\n".join(lines) + "\n")
    # Refresh cached config
    global _config
    _config = None


def read_ledger(name):
    path = ledger_path(name)
    if not path.exists():
        print(f"Ledger '{name}' not found.")
        return None
    with open(path, newline="") as f:
        rows = list(csv.DictReader(f))
        for r in rows:
            if "notes" not in r:
                r["notes"] = ""
        return rows


def write_ledger(name, rows):
    path = ledger_path(name)
    with open(path, "w", newline="") as f:
        w = csv.DictWriter(f, fieldnames=FIELDNAMES)
        w.writeheader()
        w.writerows(rows)


def next_id(rows):
    if not rows:
        return 1
    return max(int(r["id"]) for r in rows) + 1


def parse_date_or_relative(val):
    """Parse YYYY-MM-DD, 'today', or relative like +2w, +30d, +3m."""
    if val == "today":
        return date.today()
    m = re.match(r"^\+(\d+)([dwm])$", val)
    if m:
        n, unit = int(m.group(1)), m.group(2)
        if unit == "d":
            return date.today() + timedelta(days=n)
        elif unit == "w":
            return date.today() + timedelta(weeks=n)
        elif unit == "m":
            return date.today() + timedelta(days=n * 30)
    return date.fromisoformat(val)


def parse_amount_filter(val):
    """Parse an amount filter like '>=100', '<50', '=25.00'."""
    m = re.match(r"^(>=|<=|>|<|=)(.+)$", val)
    if not m:
        return None
    op, amt = m.group(1), m.group(2)
    try:
        threshold = Decimal(amt)
    except InvalidOperation:
        return None
    return (op, threshold)


def format_table(rows, include_future=False, start_date=None, end_date=None, status_filter=None, sort_order="desc", limit=None, amount_filter=None, offset=0):
    """Format rows into a table with debit/credit/balance columns. Returns total count for pagination."""
    filtered = []
    for r in sorted(rows, key=lambda x: (x["date"], int(x["id"]))):
        s = r["status"]
        if not include_future and s == "future":
            continue
        if status_filter and s != status_filter and status_filter != "all":
            continue
        rd = date.fromisoformat(r["date"])
        if start_date and rd < start_date:
            continue
        if end_date and rd > end_date:
            continue
        if amount_filter:
            op, threshold = amount_filter
            amt = abs(Decimal(r["amount"]))
            if op == ">=" and not (amt >= threshold):
                continue
            elif op == "<=" and not (amt <= threshold):
                continue
            elif op == ">" and not (amt > threshold):
                continue
            elif op == "<" and not (amt < threshold):
                continue
            elif op == "=" and not (amt == threshold):
                continue
        filtered.append(r)

    if not filtered:
        print("  No transactions.")
        return

    # Compute running balance from ALL rows up to each displayed row
    all_sorted = sorted(rows, key=lambda x: (x["date"], int(x["id"])))
    balance = Decimal("0")
    balances = {}
    for r in all_sorted:
        if not include_future and r["status"] == "future":
            continue
        balance += Decimal(r["amount"])
        balances[r["id"]] = balance

    # For forecast, include future in balance calc
    if include_future:
        balance = Decimal("0")
        balances = {}
        for r in all_sorted:
            balance += Decimal(r["amount"])
            balances[r["id"]] = balance

    if sort_order == "desc":
        filtered = list(reversed(filtered))

    total = len(filtered)
    if limit is None:
        limit = 20
    if limit == 0:
        hidden = 0
    else:
        filtered = filtered[offset:offset + limit]
        hidden = total - offset - len(filtered)

    hdr = f"  {'#':>4}  {'Date':<10}  {'Description':<20}  {'Debit':>10}  {'Credit':>10}  {'Balance':>11}  {'Status':<10}"
    print(hdr)
    print(f"  {'─'*4}  {'─'*10}  {'─'*20}  {'─'*10}  {'─'*10}  {'─'*11}  {'─'*10}")
    for r in filtered:
        amt = Decimal(r["amount"])
        debit = "$" + f"{abs(amt):,.2f}".rjust(9) if amt < 0 else " " * 10
        credit = "$" + f"{amt:,.2f}".rjust(9) if amt > 0 else " " * 10
        bal = balances.get(r["id"], Decimal("0"))
        bal_str = "$" + f"{bal:,.2f}".rjust(10)
        st = r["status"] if r["status"] != "starting" else ""
        desc = r["description"][:19] + "…" if len(r["description"]) > 20 else r["description"]
        print(f"  {r['id']:>4}  {r['date']:<10}  {desc:<20}  {debit}  {credit}  {bal_str}  {st}")
    if hidden > 0:
        print(f"  ...{hidden} more transaction{'s' if hidden != 1 else ''}. Use 'show next' or --limit to see more.")
    return total


# --- Commands ---

def cmd_create(args):
    name = args.name
    # Determine CSV path
    if hasattr(args, "path") and args.path:
        path = Path(args.path).expanduser()
        path.parent.mkdir(parents=True, exist_ok=True)
    else:
        path = ledger_path(name)
    if path.exists():
        print(f"Ledger '{name}' already exists at {path}.")
        return
    balance = args.balance if args.balance else "0.00"
    rows = [{
        "id": "1",
        "date": date.today().isoformat(),
        "description": "Opening balance",
        "amount": balance,
        "category": "",
        "status": "starting",
        "notes": "",
    }]
    with open(path, "w", newline="") as f:
        w = csv.DictWriter(f, fieldnames=FIELDNAMES)
        w.writeheader()
        w.writerows(rows)
    # Register in config
    config_file = Path(args.config_file) if hasattr(args, "config_file") and args.config_file else None
    add_ledger_to_config(name, str(path), config_file=config_file)
    print(f"Created: {path}")


def cmd_show(args):
    if not args.ledger:
        ledgers = list_ledgers()
        if not ledgers:
            print("No ledgers. Use 'create <name>' to create one.")
        else:
            for l in ledgers:
                print(f"  {l}")
        return
    rows = read_ledger(args.ledger)
    if rows is None:
        return
    start = parse_date_or_relative(args.start_date) if args.start_date else None
    end = parse_date_or_relative(args.end_date) if args.end_date else date.today()
    status_filter = args.status if hasattr(args, "status") and args.status else None
    sort_order = args.sort if hasattr(args, "sort") and args.sort else "desc"
    limit = args.limit if hasattr(args, "limit") else None
    amount_filter = parse_amount_filter(args.amount) if hasattr(args, "amount") and args.amount else None
    format_table(rows, include_future=False, start_date=start, end_date=end, status_filter=status_filter, sort_order=sort_order, limit=limit, amount_filter=amount_filter)


def cmd_forecast(args):
    rows = read_ledger(args.ledger)
    if rows is None:
        return
    end = parse_date_or_relative(args.d) if args.d else date.today() + timedelta(days=30)
    start = parse_date_or_relative(args.start_date) if args.start_date else None
    sort_order = args.sort if hasattr(args, "sort") and args.sort else "desc"
    limit = args.limit if hasattr(args, "limit") else None
    amount_filter = parse_amount_filter(args.amount) if hasattr(args, "amount") and args.amount else None
    format_table(rows, include_future=True, start_date=start, end_date=end, sort_order=sort_order, limit=limit, amount_filter=amount_filter)


def cmd_add_noninteractive(args):
    rows = read_ledger(args.ledger)
    if rows is None:
        return
    d = args.date if args.date else date.today().isoformat()
    status = "future" if date.fromisoformat(d) > date.today() else "pending"
    rows.append({
        "id": str(next_id(rows)),
        "date": d,
        "description": args.desc,
        "amount": args.amount,
        "category": args.category or "",
        "status": status,
        "notes": args.notes or "",
    })
    write_ledger(args.ledger, rows)
    print("Added.")


def cmd_clear_noninteractive(args):
    rows = read_ledger(args.ledger)
    if rows is None:
        return
    ids = set(args.ids)
    for r in rows:
        if r["id"] in ids:
            r["status"] = "cleared"
    write_ledger(args.ledger, rows)
    print("Cleared.")


def cmd_delete_noninteractive(args):
    rows = read_ledger(args.ledger)
    if rows is None:
        return
    ids = set(args.ids)
    to_delete = [r for r in rows if r["id"] in ids]
    if not to_delete:
        print("No matching transactions.")
        return
    for r in to_delete:
        amt = Decimal(r["amount"])
        sign = f"-{abs(amt):.2f}" if amt < 0 else f"{amt:.2f}"
        print(f"  #{r['id']}  {r['date']}  {r['description']}  {sign}  {r['category']}")
    try:
        confirm = input("  Delete? [y/N]: ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print("\n  Cancelled.")
        return
    if confirm != "y":
        print("  Cancelled.")
        return
    rows = [r for r in rows if r["id"] not in ids]
    write_ledger(args.ledger, rows)
    print("Deleted.")


# --- Interactive REPL ---

class FiskRepl(cmd.Cmd):
    prompt = "fisk> "

    def __init__(self):
        super().__init__()
        self._last_show = None  # stores params for pagination

    def do_show(self, line):
        """show [ledger] [--start-date DATE] [--end-date DATE] [--status STATUS]"""
        parts = line.split()
        if not parts:
            for l in list_ledgers():
                print(f"  {l}")
            return
        if parts[0] == "next":
            self.do_next(" ".join(parts[1:]))
            return
        name = parts[0]
        rows = read_ledger(name)
        if rows is None:
            return
        # Parse inline flags
        start, end, status, sort_order, limit, amount_filter = None, date.today(), None, "desc", None, None
        i = 1
        while i < len(parts):
            if parts[i] == "--start-date" and i + 1 < len(parts):
                start = parse_date_or_relative(parts[i + 1])
                i += 2
            elif parts[i] == "--end-date" and i + 1 < len(parts):
                end = parse_date_or_relative(parts[i + 1])
                i += 2
            elif parts[i] == "--status" and i + 1 < len(parts):
                status = parts[i + 1]
                i += 2
            elif parts[i] == "--sort" and i + 1 < len(parts):
                sort_order = parts[i + 1]
                i += 2
            elif parts[i] == "--limit" and i + 1 < len(parts):
                limit = int(parts[i + 1])
                i += 2
            elif parts[i] == "--amount" and i + 1 < len(parts):
                amount_filter = parse_amount_filter(parts[i + 1])
                i += 2
            else:
                i += 1
        effective_limit = limit if limit is not None else 20
        self._last_show = {
            "name": name, "start": start, "end": end, "status": status,
            "sort_order": sort_order, "limit": effective_limit, "amount_filter": amount_filter,
            "offset": effective_limit,
        }
        format_table(rows, include_future=False, start_date=start, end_date=end, status_filter=status, sort_order=sort_order, limit=limit, amount_filter=amount_filter)

    def do_next(self, line):
        """show next [--limit N] - show the next page of transactions"""
        if not self._last_show:
            print("  No previous show command. Run 'show <ledger>' first.")
            return
        parts = line.split()
        limit = self._last_show["limit"]
        i = 0
        while i < len(parts):
            if parts[i] == "--limit" and i + 1 < len(parts):
                limit = int(parts[i + 1])
                i += 2
            else:
                i += 1
        p = self._last_show
        rows = read_ledger(p["name"])
        if rows is None:
            return
        format_table(rows, include_future=False, start_date=p["start"], end_date=p["end"],
                     status_filter=p["status"], sort_order=p["sort_order"], limit=limit,
                     amount_filter=p["amount_filter"], offset=p["offset"])
        p["offset"] += limit

    def do_forecast(self, line):
        """forecast <ledger> [-d DATE|DURATION]"""
        parts = line.split()
        if not parts:
            print("Usage: forecast <ledger> [-d DATE|DURATION]")
            return
        name = parts[0]
        rows = read_ledger(name)
        if rows is None:
            return
        end = date.today() + timedelta(days=30)
        start = None
        sort_order = "desc"
        limit = None
        amount_filter = None
        i = 1
        while i < len(parts):
            if parts[i] == "-d" and i + 1 < len(parts):
                end = parse_date_or_relative(parts[i + 1])
                i += 2
            elif parts[i] == "--start-date" and i + 1 < len(parts):
                start = parse_date_or_relative(parts[i + 1])
                i += 2
            elif parts[i] == "--sort" and i + 1 < len(parts):
                sort_order = parts[i + 1]
                i += 2
            elif parts[i] == "--limit" and i + 1 < len(parts):
                limit = int(parts[i + 1])
                i += 2
            elif parts[i] == "--amount" and i + 1 < len(parts):
                amount_filter = parse_amount_filter(parts[i + 1])
                i += 2
            else:
                i += 1
        format_table(rows, include_future=True, start_date=start, end_date=end, sort_order=sort_order, limit=limit, amount_filter=amount_filter)

    def do_create(self, line):
        """create <name> [--balance AMOUNT] [--path PATH] [--config FILE]"""
        parts = line.split()
        if not parts:
            print("Usage: create <name> [--balance AMOUNT] [--path PATH] [--config FILE]")
            return
        name = parts[0]
        balance = "0.00"
        csv_path = None
        cfg_file = None
        i = 1
        while i < len(parts):
            if parts[i] == "--balance" and i + 1 < len(parts):
                balance = parts[i + 1]
                i += 2
            elif parts[i] == "--path" and i + 1 < len(parts):
                csv_path = parts[i + 1]
                i += 2
            elif parts[i] == "--config" and i + 1 < len(parts):
                cfg_file = parts[i + 1]
                i += 2
            else:
                i += 1
        if csv_path:
            path = Path(csv_path).expanduser()
            path.parent.mkdir(parents=True, exist_ok=True)
        else:
            path = ledger_path(name)
        if path.exists():
            print(f"Ledger '{name}' already exists at {path}.")
            return
        rows = [{
            "id": "1",
            "date": date.today().isoformat(),
            "description": "Opening balance",
            "amount": balance,
            "category": "",
            "status": "starting",
            "notes": "",
        }]
        with open(path, "w", newline="") as f:
            w = csv.DictWriter(f, fieldnames=FIELDNAMES)
            w.writeheader()
            w.writerows(rows)
        add_ledger_to_config(name, str(path), config_file=cfg_file)
        print(f"Created: {path}")

    def do_use(self, line):
        """use <ledger> - enter interactive mode for a ledger"""
        name = line.strip()
        if not name:
            print("Usage: use <name>")
            return
        if not ledger_path(name).exists():
            print(f"Ledger '{name}' not found.")
            return
        LedgerRepl(name).cmdloop()

    def do_quit(self, line):
        """Exit fisk"""
        return True

    def do_exit(self, line):
        """Exit fisk"""
        return True

    do_EOF = do_quit


