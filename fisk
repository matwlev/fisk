            return
        row = next((r for r in rows if r["id"] == tid), None)
        if not row:
            print(f"  Transaction {tid} not found.")
            return
        descriptions = sorted(set(r["description"] for r in rows if r["status"] != "starting"))
        categories = sorted(set(r["category"] for r in rows if r["category"]))
        try:
            new_date = input(f"  Date [{row['date']}]: ").strip()
            if new_date:
                if not validate_date(new_date):
                    print("  Invalid date. Use YYYY-MM-DD, 'today', or +Nd/+Nw/+Nm.")
                    return
                row["date"] = parse_date_or_relative(new_date).isoformat()
            row["description"] = input_with_completion(f"  Description [{row['description']}]: ", descriptions).strip() or row["description"]
            amt = input(f"  Amount [{row['amount']}]: ").strip()
            if amt:
                Decimal(amt)
                row["amount"] = amt
            row["category"] = input_with_completion(f"  Category [{row['category']}]: ", categories).strip() or row["category"]
            current_notes = row.get("notes", "")
            row["notes"] = input(f"  Notes [{current_notes}]: ").strip() or current_notes
        except (EOFError, KeyboardInterrupt):
            print("\n  Cancelled.")
            return
        except InvalidOperation:
            print("  Invalid amount.")
            return
        write_ledger(self.name, rows)
        print("  Updated.")

    def do_delete(self, line):
        """delete <id> [id...] - remove transactions"""
        ids = line.split()
        if not ids:
            print("Usage: delete <id> [id...]")
            return
        rows = read_ledger(self.name)
        if rows is None:
            return
        to_delete = [r for r in rows if r["id"] in set(ids)]
        if not to_delete:
            print("  No matching transactions.")
            return
        for r in to_delete:
            amt = Decimal(r["amount"])
            sign = f"-{abs(amt):.2f}" if amt < 0 else f"{amt:.2f}"
            print(f"  #{r['id']}  {r['date']}  {r['description']}  {sign}  {r['category']}")
        try:
            confirm = input("  Delete? [y/N]: ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            print("\n  Cancelled.")
            return
        if confirm != "y":
            print("  Cancelled.")
            return
        rows = [r for r in rows if r["id"] not in set(ids)]
        write_ledger(self.name, rows)
        print("  Deleted.")

    def do_clear(self, line):
        """clear <id> [id...] - mark transactions as cleared"""
        ids = line.split()
        if not ids:
            print("Usage: clear <id> [id...]")
            return
        rows = read_ledger(self.name)
        if rows is None:
            return
        to_clear = [r for r in rows if r["id"] in set(ids)]
        if not to_clear:
            print("  No matching transactions.")
            return
        for r in to_clear:
            amt = Decimal(r["amount"])
            sign = f"-{abs(amt):.2f}" if amt < 0 else f"{amt:.2f}"
            print(f"  #{r['id']}  {r['date']}  {r['description']}  {sign}")
        try:
            confirm = input("  Mark as cleared? [Y/n]: ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            print("\n  Cancelled.")
            return
        if confirm and confirm != "y":
            print("  Cancelled.")
            return
        for r in rows:
            if r["id"] in set(ids):
                r["status"] = "cleared"
        write_ledger(self.name, rows)
        print("  Cleared.")

    def do_details(self, line):
        """details <id> - show full details of a transaction"""
        tid = line.strip()
        if not tid:
            print("Usage: details <id>")
            return
        rows = read_ledger(self.name)
        if rows is None:
            return
        row = next((r for r in rows if r["id"] == tid), None)
        if not row:
            print(f"  Transaction {tid} not found.")
            return
        amt = Decimal(row["amount"])
        print(f"  ID:          {row['id']}")
        print(f"  Date:        {row['date']}")
        print(f"  Description: {row['description']}")
        print(f"  Amount:      {amt:.2f}")
        print(f"  Category:    {row['category'] or '—'}")
        print(f"  Status:      {row['status']}")
        notes = row.get("notes", "")
        # Parse bill linkage from notes
        m = re.match(r"^bill:([^:]+):(\d+)$", notes)
        if m:
            bf_name, bill_id = m.group(1), m.group(2)
            bills = read_bills(bf_name)
            bill = next((b for b in bills if b["id"] == bill_id), None) if bills else None
            bill_label = f"{bf_name}/{bill['name']}" if bill else f"{bf_name}/#{bill_id}"
            print(f"  Linked bill: {bill_label}")
            # Find the instance
            instances = read_instances(bf_name)
            inst = next((i for i in instances if i["bill_id"] == bill_id and i["ledger"] == self.name and i["transaction_id"] == tid), None)
            if inst:
                print(f"  Due date:    {inst['due_date']}")
                print(f"  Paid date:   {inst['paid_date']}")
        else:
            print(f"  Notes:       {notes or '—'}")

    def do_reconcile(self, line):
        """reconcile - walk through unreconciled transactions and verify balance"""
        rows = read_ledger(self.name)
        if rows is None:
            return
        try:
            stmt_balance = input("  Statement ending balance: ").strip()
            stmt_balance = Decimal(stmt_balance)
            stmt_date = input(f"  Statement date [{date.today().isoformat()}]: ").strip() or date.today().isoformat()
            stmt_date = date.fromisoformat(stmt_date)
        except (EOFError, KeyboardInterrupt):
            print("\n  Cancelled.")
            return
        except (InvalidOperation, ValueError):
            print("  Invalid input.")
            return

        # Find unreconciled transactions (pending or cleared) through statement date
        eligible = [r for r in sorted(rows, key=lambda x: (x["date"], int(x["id"])))
                    if r["status"] in ("pending", "cleared")
                    and date.fromisoformat(r["date"]) <= stmt_date]

        if not eligible:
            print("  No unreconciled transactions found.")
            return

        print(f"\n  {len(eligible)} unreconciled transaction(s) through {stmt_date}:\n")
        reconciled_ids = []
        for r in eligible:
            amt = Decimal(r["amount"])
            sign = f"-{abs(amt):.2f}" if amt < 0 else f"{amt:.2f}"
            try:
                resp = input(f"  #{r['id']}  {r['date']}  {r['description']}  {sign}  [Y/n/s]: ").strip().lower()
            except (EOFError, KeyboardInterrupt):
                print("\n  Stopping.")
                break
            if resp in ("", "y"):
                reconciled_ids.append(r["id"])
            elif resp == "n":
                print("    Flagged — skipping.")
            # 's' or anything else = skip silently

        # Compute reconciled balance
        previously_reconciled = sum(
            Decimal(r["amount"]) for r in rows if r["status"] == "reconciled"
        )
        newly_reconciled = sum(
            Decimal(r["amount"]) for r in rows if r["id"] in set(reconciled_ids)
        )
        # Include starting balance
        starting = sum(Decimal(r["amount"]) for r in rows if r["status"] == "starting")
        computed_balance = starting + previously_reconciled + newly_reconciled

        print(f"\n  Reconciled balance: {computed_balance:.2f}")
        print(f"  Statement balance:  {stmt_balance:.2f}", end="")
        if computed_balance == stmt_balance:
            print("  ✓ Balanced!")
        else:
            diff = computed_balance - stmt_balance
            print(f"  ✗ Difference: {diff:.2f}")
            try:
                proceed = input("  Balances don't match. Reconcile anyway? [y/N]: ").strip().lower()
            except (EOFError, KeyboardInterrupt):
                print("\n  Cancelled.")
                return
            if proceed != "y":
                print("  Cancelled. No changes made.")
                return

        # Apply
        for r in rows:
            if r["id"] in set(reconciled_ids):
                r["status"] = "reconciled"
        write_ledger(self.name, rows)
        print(f"  {len(reconciled_ids)} transaction(s) reconciled.")

    def do_sort(self, line):
        """sort - sort all by date; sort <id> <position> - move a transaction to a position"""
        rows = read_ledger(self.name)
        if rows is None:
            return
        parts = line.split()

        if len(parts) == 2:
            # Move a single transaction to a new position
            src_id, dest_pos = parts[0], parts[1]
            try:
                dest_pos = int(dest_pos)
            except ValueError:
                print("  Usage: sort <id> <position>")
                return
            row = next((r for r in rows if r["id"] == src_id), None)
            if not row:
                print(f"  Transaction {src_id} not found.")
                return
            rows.remove(row)
            idx = max(0, min(dest_pos - 1, len(rows)))
            rows.insert(idx, row)
            for i, r in enumerate(rows, 1):
                r["id"] = str(i)
            write_ledger(self.name, rows)
            print(f"  Moved to #{dest_pos}. IDs reassigned.")
            return

        if parts:
            print("  Usage: sort (sort all by date) or sort <id> <position>")
            return

        # Full sort by date
        print("  Current order:")
        for r in rows:
            amt = Decimal(r["amount"])
            sign = f"-{abs(amt):.2f}" if amt < 0 else f"{amt:.2f}"
            print(f"    #{r['id']}  {r['date']}  {r['description']}  {sign}")
        sorted_rows = sorted(rows, key=lambda x: (x["date"], int(x["id"])))
        print("\n  Sorted order:")
        for i, r in enumerate(sorted_rows, 1):
            amt = Decimal(r["amount"])
            sign = f"-{abs(amt):.2f}" if amt < 0 else f"{amt:.2f}"
            print(f"    #{i}  {r['date']}  {r['description']}  {sign}")
        try:
            confirm = input("\n  Apply this sort and reassign IDs? [y/N]: ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            print("\n  Cancelled.")
            return
        if confirm != "y":
            print("  Cancelled.")
            return
        for i, r in enumerate(sorted_rows, 1):
            r["id"] = str(i)
        write_ledger(self.name, sorted_rows)
        print("  Sorted.")

    def do_back(self, line):
        """Return to fisk prompt"""
        return True

    def do_quit(self, line):
        """Exit fisk entirely"""
        sys.exit(0)

    do_EOF = do_back


class BillsRepl(cmd.Cmd):
    def __init__(self, name):
        super().__init__()
        self.name = name
        self.prompt = f"{name}> "

    def do_show(self, line):
        """show - show upcoming bill instances (predicted/unpaid/paid)"""
        bills = read_bills(self.name)
        if not bills:
            print("  No bills.")
            return
        all_instances = generate_predicted_instances(self.name)
        if not all_instances:
            print("  No upcoming bills.")
            return
        # Build bill name lookup
        bill_map = {b["id"]: b for b in bills}
        # Sort by due_date
        all_instances.sort(key=lambda x: x["due_date"])
        # Show only within 90 days
        today = date.today()
        end = today + timedelta(days=90)
        shown = [i for i in all_instances if i["due_date"] <= end.isoformat() and i["status"] != "paid"]
        # Also show recently paid (last 30 days)
        recent_paid = [i for i in all_instances if i["status"] == "paid" and i["paid_date"] >= (today - timedelta(days=30)).isoformat()]
        display = shown + recent_paid
        display.sort(key=lambda x: x["due_date"])
        if not display:
            print("  No upcoming bills.")
            return
        print(f"  {'Bill':<18} {'Amount':>10}  {'Due':<10}  {'Status':<10}  {'Paid':<10}")
        print(f"  {'─'*18} {'─'*10}  {'─'*10}  {'─'*10}  {'─'*10}")
        for inst in display:
            bill = bill_map.get(inst["bill_id"])
            name = bill["name"] if bill else f"(bill {inst['bill_id']})"
            amt_str = ""
            if inst["amount"]:
                if inst["amount"].startswith("~"):
                    amt_str = f"~${Decimal(inst['amount'][1:]):>8,.2f}"
                else:
                    amt_str = f" ${Decimal(inst['amount']):>8,.2f}"
            due_str = date.fromisoformat(inst["due_date"]).strftime("%b %d")
            paid_str = inst["paid_date"] if inst["paid_date"] else ""
            print(f"  {name:<18} {amt_str:>10}  {due_str:<10}  {inst['status']:<10}  {paid_str:<10}")

    def do_add(self, line):
        """add - add a new recurring bill"""
        bills = read_bills(self.name)
        if bills is None:
            bills = []
        try:
            name = input("  Name: ").strip()
            if not name:
                print("  Cancelled.")
                return
            amount = input("  Amount: ").strip()
            Decimal(amount)
            category = input("  Category []: ").strip()
            print("  Frequency (monthly, bimonthly, quarterly, semiannual, annual, or Nd e.g. 14d):")
            frequency = input("  Frequency: ").strip()
            due_day = ""
            if frequency in ("monthly", "bimonthly", "quarterly", "semiannual", "annual"):
                due_day = input("  Due day of month: ").strip()
