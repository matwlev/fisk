def cmd_bills(args):
    """Handle non-interactive bills command."""
    if not args.bill_file:
        # List bill files
        bill_files = list_bill_files()
        if not bill_files:
            print("No bill files configured. Add a [bills] section to config.")
        else:
            for b in bill_files:
                print(f"  {b}")
        return

    # Handle: fisk bills create <name> [--path PATH]
    if args.bill_file == "create":
        name = args.action  # positional shift: 'create' ate bill_file, name lands in action
        if not name:
            print("Usage: fisk bills create <name> [--path PATH]")
            return
        if args.bill_path:
            path = Path(args.bill_path).expanduser()
            path.parent.mkdir(parents=True, exist_ok=True)
        else:
            path = get_ledger_dir() / f"{name}.csv"
        if path.exists():
            print(f"Bill file '{name}' already exists at {path}.")
            return
        with open(path, "w", newline="") as f:
            w = csv.DictWriter(f, fieldnames=BILL_FIELDNAMES)
            w.writeheader()
        add_bills_to_config(name, str(path))
        print(f"Created: {path}")
        return

    if not args.action or args.action == "show":
        # Show upcoming bills from this file
        bills = read_bills(args.bill_file)
        if not bills:
            return
        today = date.today()
        end = today + timedelta(days=90)
        show_source = args.source if hasattr(args, "source") else False
        print(f"  {'Bill':<18} {'Amount':>10}  {'Due':<10}  {'Status':<8}  {'Likely match'}")
        print(f"  {'─'*18} {'─'*10}  {'─'*10}  {'─'*8}  {'─'*30}")
        for bill in bills:
            next_due = get_next_due(bill)
            if not next_due or next_due > end:
                continue
            amt, is_estimate = get_bill_amount(bill)
            match = find_likely_match(bill, next_due)
            match_str = match or ""
            source_str = f"  [{args.bill_file}]" if show_source else ""
            if amt is not None:
                prefix = "~$" if is_estimate else " $"
                print(f"  {bill['name']:<18} {prefix}{amt:>8,.2f}  {next_due.strftime('%b %d'):<10}  unpaid    {match_str}{source_str}")
            else:
                print(f"  {bill['name']:<18} {'':>10}  {next_due.strftime('%b %d'):<10}  unpaid    {match_str}{source_str}")

    elif args.action == "pay":
        if not args.bill_name:
            print("Usage: fisk bills <file> pay <bill name> [--add <ledger>]")
            return
        pay_bill(args.bill_file, args.bill_name, add_ledger=args.add_ledger, paid_date=args.paid_date if hasattr(args, "paid_date") else None)

    elif args.action == "receive":
        if not args.bill_name:
            print("Usage: fisk bills <file> receive <bill name> [--due DATE] [--amount AMT]")
            return
        bills = read_bills(args.bill_file)
        if not bills:
            return
        bill = next((b for b in bills if b["name"].lower() == args.bill_name.lower()), None)
        if not bill:
            print(f"  Bill '{args.bill_name}' not found.")
            return
        due_str = args.due_date if hasattr(args, "due_date") and args.due_date else None
        if not due_str:
            next_due = get_next_due(bill)
            due_str = next_due.isoformat() if next_due else None
        if not due_str:
            print("  Could not determine due date. Use --due.")
            return
        due_str = parse_date_or_relative(due_str).isoformat()
        amt_str = args.receive_amount if hasattr(args, "receive_amount") and args.receive_amount else (bill["amount"] or "")
        instances = read_instances(args.bill_file)
        existing = next((i for i in instances if i["bill_id"] == bill["id"] and i["due_date"] == due_str), None)
        if existing:
            existing["amount"] = amt_str
            existing["status"] = "unpaid"
        else:
            instances.append({
                "id": str(next_instance_id(instances)),
                "bill_id": bill["id"],
                "due_date": due_str,
                "amount": amt_str,
                "paid_date": "",
                "status": "unpaid",
                "ledger": "",
                "transaction_id": "",
            })
        write_instances(args.bill_file, instances)
        amt_display = f" — ${Decimal(amt_str):,.2f}" if amt_str else ""
        print(f"  ✓ {bill['name']} due {due_str}{amt_display}")


def build_parser():
    parser = argparse.ArgumentParser(
        prog="fisk",
        description="Personal finance ledger. Run with no arguments for interactive mode.",
    )
    parser.add_argument("--version", action="version", version=f"fisk {VERSION}")
    sub = parser.add_subparsers(dest="command")

    p = sub.add_parser("create", help="Create a new ledger")
    p.add_argument("name", help="Ledger name")
    p.add_argument("--balance", default="0.00", help="Starting balance (default: 0.00)")
    p.add_argument("--path", help="Path for the CSV file")
    p.add_argument("--config", dest="config_file", help="Config file to register the ledger in")

    p = sub.add_parser("show", help="List ledgers or display a ledger")
    p.add_argument("ledger", nargs="?", help="Ledger to display (omit to list all)")
    p.add_argument("--start-date", help="Show transactions from this date (YYYY-MM-DD or 'today')")
    p.add_argument("--end-date", help="Show transactions through this date (default: today)")
    p.add_argument("--status", help="Filter by status: pending, cleared, all")
    p.add_argument("--sort", choices=["asc", "desc"], default="desc", help="Sort order: asc or desc (default: desc)")
    p.add_argument("--limit", type=int, help="Maximum number of transactions to display")
    p.add_argument("--amount", help="Filter by amount (e.g. '>=100', '<50', '=25.00')")
    p.add_argument("--source", action="store_true", help="Show source file for each bill")

    p = sub.add_parser("forecast", help="Show ledger including future transactions")
    p.add_argument("ledger", help="Ledger to forecast")
    p.add_argument("-d", default=None, help="Target date or duration (YYYY-MM-DD, +2w, +30d, +3m)")
    p.add_argument("--start-date", help="Show transactions from this date")
    p.add_argument("--sort", choices=["asc", "desc"], default="desc", help="Sort order: asc or desc (default: desc)")
    p.add_argument("--limit", type=int, help="Maximum number of transactions to display")
    p.add_argument("--amount", help="Filter by amount (e.g. '>=100', '<50', '=25.00')")

    p = sub.add_parser("add", help="Add a transaction")
    p.add_argument("ledger", help="Ledger to add to")
    p.add_argument("--date", help="Transaction date (default: today)")
    p.add_argument("--desc", required=True, help="Description")
    p.add_argument("--amount", required=True, help="Amount (positive for credit, negative for debit)")
    p.add_argument("--category", default="", help="Category (optional)")
    p.add_argument("--notes", default="", help="Notes (optional)")

    p = sub.add_parser("clear", help="Mark transactions as cleared")
    p.add_argument("ledger", help="Ledger name")
    p.add_argument("ids", nargs="+", help="Transaction IDs to clear")

    p = sub.add_parser("delete", help="Delete transactions (with confirmation)")
    p.add_argument("ledger", help="Ledger name")
    p.add_argument("ids", nargs="+", help="Transaction IDs to delete")

    p = sub.add_parser("import", help="Import transactions from an external CSV")
    p.add_argument("ledger", help="Ledger to import into")
    p.add_argument("--file", required=True, help="Path to the source CSV file")
    p.add_argument("--date-col", help="Name of the date column")
    p.add_argument("--date-format", help="strptime format for dates (e.g. '%%a. %%m/%%d/%%y' for 'Fri. 06/05/26')")
    p.add_argument("--desc-col", help="Name of the description column")
    p.add_argument("--amount-col", help="Name of a single amount column (signed)")
    p.add_argument("--credit-col", help="Name of the credit column")
    p.add_argument("--debit-col", help="Name of the debit column")
    p.add_argument("--category-col", help="Name of the category column")
    p.add_argument("--cleared-col", help="Name of the cleared/checkmark column")

    p = sub.add_parser("sort", help="Sort transactions or move a transaction to a position")
    p.add_argument("ledger", help="Ledger name")
    p.add_argument("id", nargs="?", help="Transaction ID to move")
    p.add_argument("position", nargs="?", type=int, help="Target position")

    p = sub.add_parser("summary", help="Summary statistics for a ledger")
    p.add_argument("ledger", help="Ledger name")
    p.add_argument("--description", help="Filter by description (partial match)")
    p.add_argument("--category", help="Filter by category (exact match)")
    p.add_argument("--start-date", help="Include transactions from this date")
    p.add_argument("--end-date", help="Include transactions through this date")

    p = sub.add_parser("bills", help="Manage recurring bills")
    p.add_argument("bill_file", nargs="?", help="Bill file name")
    p.add_argument("action", nargs="?", help="Action: show, pay, receive, or create")
    p.add_argument("bill_name", nargs="?", help="Bill name (for pay/receive) or file name (for create)")
    p.add_argument("--add", dest="add_ledger", help="Also add transaction to this ledger (for pay)")
    p.add_argument("--source", action="store_true", help="Show source file for each bill")
    p.add_argument("--path", dest="bill_path", help="Path for the bills CSV file (for create)")
    p.add_argument("--due", dest="due_date", help="Due date for receive")
    p.add_argument("--amount", dest="receive_amount", help="Amount for receive")
    p.add_argument("--date", dest="paid_date", help="Payment date for pay (default: today)")

    return parser


def main():
    if len(sys.argv) == 1:
        FiskRepl().cmdloop()
        return

    parser = build_parser()
    args = parser.parse_args()

    if args.command == "create":
        cmd_create(args)
    elif args.command == "show":
        cmd_show(args)
    elif args.command == "forecast":
        cmd_forecast(args)
    elif args.command == "add":
        cmd_add_noninteractive(args)
    elif args.command == "clear":
        cmd_clear_noninteractive(args)
    elif args.command == "delete":
        cmd_delete_noninteractive(args)
    elif args.command == "import":
        cmd_import(args)
    elif args.command == "sort":
        cmd_sort_noninteractive(args)
    elif args.command == "summary":
        cmd_summary(args)
    elif args.command == "bills":
        cmd_bills(args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
