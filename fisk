            print("  Invalid amount.")
            return
        status = "future" if date.fromisoformat(d) > date.today() else "pending"
        rows.append({
            "id": str(next_id(rows)),
            "date": d,
            "description": desc,
            "amount": amt,
            "category": cat,
            "status": status,
            "notes": notes,
        })
